@page
@model FlightPrep.Pages.LoginModel
@{
    ViewData["Title"] = "Inloggen";
}

<div class="container d-flex justify-content-center align-items-center" style="min-height: 100vh;">
    <div class="card shadow-sm" style="width: 100%; max-width: 440px;">
        <div class="card-body p-4">
            <div class="text-center mb-4">
                <h4 class="fw-bold mb-0" style="color: #0B2340;">🎈 FlightPrep</h4>
                <p class="text-muted small mt-1">Inloggen op uw account</p>
            </div>

            @if (Model.Registered)
            {
                <div class="alert alert-info" role="alert">
                    Registratie gelukt. Uw account wacht op goedkeuring van de beheerder.
                </div>
            }

            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2" role="alert"></div>

            <form method="post">
                <input type="hidden" asp-for="ReturnUrl"/>

                <div class="mb-3">
                    <label asp-for="Input.Email" class="form-label fw-medium">E-mailadres</label>
                    <input asp-for="Input.Email" class="form-control" autocomplete="email"
                           placeholder="naam@example.com"/>
                    <span asp-validation-for="Input.Email" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Input.Password" class="form-label fw-medium">Wachtwoord</label>
                    <input asp-for="Input.Password" class="form-control" autocomplete="current-password"/>
                    <span asp-validation-for="Input.Password" class="text-danger small"></span>
                </div>

                <div class="mb-3 form-check">
                    <input asp-for="Input.RememberMe" class="form-check-input"/>
                    <label asp-for="Input.RememberMe" class="form-check-label">Onthoud mij</label>
                </div>

                <button type="submit" class="btn btn-primary w-100">Inloggen</button>
            </form>

            <hr/>

            <p class="text-center mb-0 small">
                Nog geen account? <a asp-page="/Register">Registreren</a>
            </p>
        </div>
    </div>
</div>
