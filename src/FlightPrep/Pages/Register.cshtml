@page
@model FlightPrep.Pages.RegisterModel
@{
    ViewData["Title"] = "Registreren";
}

<div class="container d-flex justify-content-center align-items-center" style="min-height: 100vh;">
    <div class="card shadow-sm" style="width: 100%; max-width: 440px;">
        <div class="card-body p-4">
            <div class="text-center mb-4">
                <h4 class="fw-bold mb-0" style="color: #0B2340;">🎈 FlightPrep</h4>
                <p class="text-muted small mt-1">Maak een nieuw account aan</p>
            </div>

            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2" role="alert"></div>

            <form method="post">
                <div class="mb-3">
                    <label asp-for="Input.Email" class="form-label fw-medium">E-mailadres</label>
                    <input asp-for="Input.Email" class="form-control" autocomplete="email" placeholder="naam@example.com" />
                    <span asp-validation-for="Input.Email" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Input.Password" class="form-label fw-medium">Wachtwoord</label>
                    <input asp-for="Input.Password" class="form-control" autocomplete="new-password" />
                    <span asp-validation-for="Input.Password" class="text-danger small"></span>
                    <div class="form-text">Minimaal 8 tekens, inclusief een cijfer.</div>
                </div>

                <div class="mb-3">
                    <label asp-for="Input.ConfirmPassword" class="form-label fw-medium">Bevestig wachtwoord</label>
                    <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" />
                    <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
                </div>

                <button type="submit" class="btn btn-primary w-100">Registreren</button>
            </form>

            <hr />

            <p class="text-center mb-0 small">
                Al een account? <a asp-page="/Login">Inloggen</a>
            </p>
        </div>
    </div>
</div>
