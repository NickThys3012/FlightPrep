<!DOCTYPE html>
<html lang="nl">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <base href="/" />
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#0B2340" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="FlightPrep" />
    <link rel="apple-touch-icon" href="/icons/icon-192.png" />
    <ResourcePreloader />
    <link rel="stylesheet" href="@Assets["lib/bootstrap/dist/css/bootstrap.min.css"]" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/quill@2/dist/quill.snow.css" />
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.2/dist/chart.umd.min.js"></script>
    <link rel="stylesheet" href="@Assets["app.css"]" />
    <link rel="stylesheet" href="@Assets["FlightPrep.styles.css"]" />
    <ImportMap />
    <link rel="icon" type="image/png" href="favicon.png" />
    <HeadOutlet />
</head>

<body>
    <Routes />
    <ReconnectModal />
    <script src="https://cdn.jsdelivr.net/npm/quill@2/dist/quill.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.2/dist/chart.umd.min.js"></script>
    <script src="@Assets["lib/bootstrap/dist/js/bootstrap.bundle.min.js"]"></script>
    <script src="https://html2canvas.hertzen.com/dist/html2canvas.min.js"></script>
    <script src="@Assets["_framework/blazor.web.js"]"></script>
    <script>
        window.downloadFileFromBytes = function (fileName, contentType, base64) {
            const a = document.createElement("a");
            a.href = `data:${contentType};base64,${base64}`;
            a.download = fileName;
            a.click();
        };

        window._flightMap = null;
        window._flightPoints = null;
        window._hoverMarker = null;

        window.initFlightMap = function(mapId, points) {
            // points: array of [lat, lon, altM]
            if (!points || points.length === 0) return;

            var map = L.map(mapId).setView([points[0][0], points[0][1]], 13);
            window._flightMap = map;
            window._flightPoints = points;

            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                attribution: '© OpenStreetMap contributors',
                maxZoom: 18
            }).addTo(map);

            // Compute altitude range for color
            var altitudes = points.map(function(p) { return p[2]; });
            var minAlt = Math.min.apply(null, altitudes);
            var maxAlt = Math.max.apply(null, altitudes);
            var range = maxAlt - minAlt || 1;

            // Draw colored polyline segments (blue low → red high)
            for (var i = 1; i < points.length; i++) {
                var t = (points[i][2] - minAlt) / range;
                var r = Math.round(t * 220);
                var b = Math.round((1 - t) * 220);
                var color = 'rgb(' + r + ',50,' + b + ')';
                L.polyline([[points[i-1][0], points[i-1][1]], [points[i][0], points[i][1]]], {
                    color: color, weight: 3, opacity: 0.85
                }).addTo(map);
            }

            // Start marker (green) and end marker (red)
            L.marker([points[0][0], points[0][1]], {
                icon: L.divIcon({ className: '', html: '<div style="background:#2ecc71;width:14px;height:14px;border-radius:50%;border:2px solid white;box-shadow:0 0 4px rgba(0,0,0,.5)"></div>', iconAnchor:[7,7] })
            }).bindPopup('Start').addTo(map);

            var last = points[points.length - 1];
            L.marker([last[0], last[1]], {
                icon: L.divIcon({ className: '', html: '<div style="background:#e74c3c;width:14px;height:14px;border-radius:50%;border:2px solid white;box-shadow:0 0 4px rgba(0,0,0,.5)"></div>', iconAnchor:[7,7] })
            }).bindPopup('Landing').addTo(map);

            // Crosshair marker (hidden until chart hover)
            window._hoverMarker = L.marker([points[0][0], points[0][1]], {
                icon: L.divIcon({ className: '', html: '<div style="background:#f39c12;width:12px;height:12px;border-radius:50%;border:2px solid white;box-shadow:0 0 6px rgba(0,0,0,.6)"></div>', iconAnchor:[6,6] }),
                zIndexOffset: 1000
            });

            // Fit bounds
            var latlngs = points.map(function(p) { return [p[0], p[1]]; });
            map.fitBounds(latlngs);
        };

        window.initAltitudeChart = function(canvasId, points) {
            // points: array of [lat, lon, altM]
            if (!points || points.length === 0) return;

            var M_TO_FT = 3.28084;

            // Compute cumulative distance (km) as x-axis, altitudes in feet
            var labels = [];
            var altitudesFt = [];
            var dist = 0;
            labels.push('0.0');
            altitudesFt.push(Math.round(points[0][2] * M_TO_FT));
            for (var i = 1; i < points.length; i++) {
                var dLat = (points[i][0] - points[i-1][0]) * Math.PI / 180;
                var dLon = (points[i][1] - points[i-1][1]) * Math.PI / 180;
                var a = Math.sin(dLat/2)*Math.sin(dLat/2) +
                        Math.cos(points[i-1][0]*Math.PI/180)*Math.cos(points[i][0]*Math.PI/180)*
                        Math.sin(dLon/2)*Math.sin(dLon/2);
                dist += 6371 * 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1-a));
                labels.push(i % 10 === 0 ? dist.toFixed(1) : '');
                altitudesFt.push(Math.round(points[i][2] * M_TO_FT));
            }

            // Color each point based on altitude (same blue→red scale as map)
            var minAlt = Math.min.apply(null, altitudesFt);
            var maxAlt = Math.max.apply(null, altitudesFt);
            var range = maxAlt - minAlt || 1;
            var pointColors = altitudesFt.map(function(a) {
                var t = (a - minAlt) / range;
                var r = Math.round(t * 220);
                var b = Math.round((1 - t) * 220);
                return 'rgba(' + r + ',50,' + b + ',0.85)';
            });

            var ctx = document.getElementById(canvasId).getContext('2d');
            new Chart(ctx, {
                type: 'line',
                data: {
                    labels: labels,
                    datasets: [{
                        label: 'Hoogte (ft)',
                        data: altitudesFt,
                        borderColor: 'rgba(26,58,92,0.7)',
                        borderWidth: 1.5,
                        pointBackgroundColor: pointColors,
                        pointRadius: 2,
                        pointHoverRadius: 6,
                        fill: true,
                        backgroundColor: 'rgba(26,58,92,0.08)',
                        tension: 0.3
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    interaction: { mode: 'index', intersect: false },
                    plugins: {
                        legend: { display: false },
                        tooltip: {
                            callbacks: {
                                title: function(items) {
                                    var d = labels[items[0].dataIndex];
                                    return d ? 'Afstand: ' + d + ' km' : '';
                                },
                                label: function(item) { return 'Hoogte: ' + item.raw + ' ft'; }
                            }
                        }
                    },
                    onHover: function(event, activeElements) {
                        if (!window._flightMap || !window._flightPoints || !window._hoverMarker) return;
                        if (activeElements && activeElements.length > 0) {
                            var idx = activeElements[0].index;
                            var pt = window._flightPoints[idx];
                            window._hoverMarker.setLatLng([pt[0], pt[1]]);
                            if (!window._hoverMarker._map) {
                                window._hoverMarker.addTo(window._flightMap);
                            }
                            var altFt = Math.round(pt[2] * M_TO_FT);
                            window._hoverMarker.bindTooltip(altFt + ' ft', { permanent: false, direction: 'top', offset: [0, -8] });
                        } else {
                            if (window._hoverMarker._map) {
                                window._hoverMarker.remove();
                            }
                        }
                    },
                    scales: {
                        x: {
                            title: { display: true, text: 'Afstand (km)' },
                            ticks: { maxRotation: 0 },
                            grid: { color: 'rgba(0,0,0,0.05)' }
                        },
                        y: {
                            title: { display: true, text: 'Hoogte (ft)' },
                            grid: { color: 'rgba(0,0,0,0.05)' },
                            beginAtZero: false
                        }
                    }
                }
            });
        };

        window._quills = {};

        window.quillInit = function (id, htmlContent) {
            const el = document.getElementById(id);
            if (!el) return;
            // Reset DOM so we never double-initialise
            if (window._quills[id]) {
                window._quills[id] = null;
            }
            el.innerHTML = '';
            const q = new Quill('#' + id, {
                theme: 'snow',
                modules: {
                    toolbar: [
                        [{ header: [1, 2, 3, false] }],
                        ['bold', 'italic', 'underline', 'strike'],
                        [{ list: 'ordered' }, { list: 'bullet' }],
                        ['clean']
                    ]
                }
            });
            if (htmlContent) q.clipboard.dangerouslyPasteHTML(htmlContent);
            window._quills[id] = q;
        };

        // Returns null when Quill was never opened (so C# keeps existing value)
        window.quillGetHtml = function (id) {
            const q = window._quills[id];
            return q ? q.root.innerHTML : null;
        };

        window.initLogboekCharts = function(monthLabels, monthData, locationLabels, locationData) {
            var ctx1 = document.getElementById('chart-months');
            if (ctx1) {
                new Chart(ctx1.getContext('2d'), {
                    type: 'bar',
                    data: {
                        labels: monthLabels,
                        datasets: [{ label: 'Vaarten', data: monthData, backgroundColor: 'rgba(26,58,92,0.75)', borderRadius: 4 }]
                    },
                    options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true, ticks: { stepSize: 1 } } } }
                });
            }
            var ctx2 = document.getElementById('chart-locations');
            if (ctx2) {
                new Chart(ctx2.getContext('2d'), {
                    type: 'bar',
                    data: {
                        labels: locationLabels,
                        datasets: [{ label: 'Vaarten', data: locationData, backgroundColor: 'rgba(41,182,246,0.75)', borderRadius: 4 }]
                    },
                    options: { responsive: true, maintainAspectRatio: false, indexAxis: 'y', plugins: { legend: { display: false } }, scales: { x: { beginAtZero: true, ticks: { stepSize: 1 } } } }
                });
            }
        };

        // Register service worker for PWA
        if ('serviceWorker' in navigator) {
            window.addEventListener('load', function() {
                navigator.serviceWorker.register('/service-worker.js')
                    .then(function(reg) { console.log('SW registered:', reg.scope); })
                    .catch(function(err) { console.log('SW registration failed:', err); });
            });
        }

        window.initTrajectoryMap = async function(containerId, trajectories, startLat, startLon) {
            const container = document.getElementById(containerId);
            if (!container) return null;

            if (container._leafletMap) {
                container._leafletMap.remove();
                container._leafletMap = null;
            }

            const map = L.map(containerId, { renderer: L.canvas() }).setView([startLat, startLon], 10);
            container._leafletMap = map;

            const tileLayer = L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                attribution: '© OpenStreetMap contributors',
                crossOrigin: 'anonymous'
            }).addTo(map);

            L.circleMarker([startLat, startLon], { radius: 8, color: '#ffffff', fillColor: '#0B2340', fillOpacity: 1, weight: 2 })
                .bindPopup('🎈 Startlocatie')
                .addTo(map);

            const allPoints = [[startLat, startLon]];
            trajectories.forEach(function(traj) {
                const latlngs = traj.points.map(function(p) { return [p[0], p[1]]; });
                allPoints.push.apply(allPoints, latlngs);
                L.polyline(latlngs, { color: traj.color, weight: 3, opacity: 0.9 }).addTo(map);
                const end = latlngs[latlngs.length - 1];
                L.circleMarker(end, { radius: 6, color: traj.color, fillColor: traj.color, fillOpacity: 0.9, weight: 2 })
                    .bindPopup('Eindpunt: ' + traj.label).addTo(map);
            });
            if (allPoints.length > 1) map.fitBounds(allPoints, { padding: [0, 0], maxZoom: 18 });

            // Capture map as PNG after tiles finish loading
            try {
                await new Promise((resolve) => {
                    tileLayer.on('load', resolve);
                    setTimeout(resolve, 4000); // fallback timeout
                });
                await new Promise(r => setTimeout(r, 500)); // settle
                const canvas = await html2canvas(container, { useCORS: true, allowTaint: false, scale: 0.75, logging: false });
                return canvas.toDataURL('image/jpeg', 0.85).split(',')[1]; // JPEG, smaller size
            } catch(e) {
                console.warn('Map capture failed:', e);
                return null;
            }
        };
    </script>
</body>

</html>
