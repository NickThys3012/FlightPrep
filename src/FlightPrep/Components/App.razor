    <HeadOutlet/>
    <script src="https://unpkg.com/html2canvas@1.4.1/dist/html2canvas.min.js"></script>
    @if (!string.IsNullOrEmpty(aiConnStr))
    {
        <script type="text/javascript">
            !function (T, l, y) {
