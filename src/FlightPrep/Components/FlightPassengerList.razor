@using System.Globalization
@rendermode InteractiveServer

<div class="row g-3 mb-3">
    <div class="col-md-4">
        <label class="form-label">Gewicht envelop+brander+mand+flessen (kg)</label>
        <input type="number" step="0.1" class="form-control" @bind="Fp.EnvelopeWeightKg"/>
    </div>
    <div class="col-md-3">
        <label class="form-label">Max Altitude (ft)</label>
        <input type="number" class="form-control" @bind="Fp.MaxAltitudeFt"/>
    </div>
    <div class="col-md-2">
        <label class="form-label">Lift units</label>
        <input type="number" step="1" class="form-control" @bind="Fp.LiftUnits"/>
    </div>
    <div class="col-md-3">
        <label class="form-label">Totaal lift (kg)</label>
        <div class="input-group">
            <input type="number" step="0.1" class="form-control" @bind="Fp.TotaalLiftKg"/>
            <button class="btn btn-outline-primary" type="button"
                    disabled="@(!CanCalculateLift)"
                    @onclick="BerekenLift"
                    title="Bereken lift via ISA formule">🧮 Bereken lift
            </button>
        </div>
    </div>
</div>

<div class="row g-2 mb-3 text-muted small">
    <div class="col-auto">
        📍 Vertreksite: <strong>@(Fp.Location?.ElevationM?.ToString("F0") ?? "–") m AMSL</strong>
    </div>
    @if (Fp.MaxAltitudeFt.HasValue)
    {
        <div class="col-auto">
            🎈 Max hoogte: <strong>≈ @((Fp.MaxAltitudeFt.Value * 0.3048).ToString("F0")) m AMSL</strong>
        </div>
    }
    <div class="col-auto">
        📦 Ballonvolume: <strong>@(Fp.Balloon?.VolumeM3?.ToString("F0") ?? "–") m³</strong>
    </div>
    <div class="col-auto">
        🌡 Envelop Ti: <strong>@(Fp.Balloon?.InternalEnvelopeTempC?.ToString("F0") ?? "–")°C</strong>
    </div>
</div>

@if (_liftResult is not null && CanCalculateLift)
{
    var altM = Fp.MaxAltitudeFt!.Value * 0.3048;
    var eg = Fp.Location!.ElevationM!.Value;
    var tg = Fp.TemperatuurC!.Value;
    var ti = Fp.Balloon!.InternalEnvelopeTempC!.Value;
    var v = Fp.Balloon!.VolumeM3!.Value;
    <div class="alert alert-info py-2 mb-3 small">
        🧮 ISA: Ta = @_liftResult.AmbientTempAtAltC.ToString("F1")°C | P = @_liftResult.PressureHpa.ToString("F1") hPa →
        <strong>@_liftResult.TotalLiftKg.ToString("F1") kg</strong>
        <div class="fp-calc-steps mt-1">
            <small class="text-muted font-monospace d-block">
                Stap 1 — Ta = @tg.ToString("F1")°C − (0,0065 × (@altM.ToString("F0") − @eg.ToString("F0")))
                = @_liftResult.AmbientTempAtAltC.ToString("F1")°C
            </small>
            <small class="text-muted font-monospace d-block">
                Stap 2 — P = 1013,25 × (1 − (0,0065 × @altM.ToString("F0")) / 288,15)^5,256
                = @_liftResult.PressureHpa.ToString("F1") hPa
            </small>
            <small class="text-muted font-monospace d-block">
                Stap 3 — L = 0,3484 × @v.ToString("F0") × @_liftResult.PressureHpa.ToString("F1") × (1/(Ta+273,15) −
                1/(@ti.ToString("F0")+273,15)) = @_liftResult.TotalLiftKg.ToString("F1") kg
            </small>
            <small class="text-muted fst-italic d-block mt-1">
                ¹ Formule: Hot Air Balloon Flight Manual, Amendment 18, Appendix 2, p. A2-1 (Cameron Balloons Ltd.)
            </small>
        </div>
    </div>
}

<h6>Gewichten</h6>
<table class="table table-sm table-bordered">
    <thead class="table-secondary">
    <tr>
        <th>Naam</th>
        <th style="width:150px">Gewicht (kg)</th>
        <th style="width:60px"></th>
    </tr>
    </thead>
    <tbody>
    <!-- Pilot row (read-only) -->
    <tr class="table-light">
        <td>
            <em>Piloot: @(CurrentPilot?.Name ?? "–")</em>
        </td>
        <td>@(CurrentPilot?.WeightKg?.ToString("F1") ?? "–")</td>
        <td></td>
    </tr>
    @for (var i = 0; i < Fp.Passengers.Count; i++)
    {
        var idx = i;
        <tr>
            <td>
                <input type="text" class="form-control form-control-sm"
                       placeholder="Naam passagier"
                       value="@Fp.Passengers[idx].Name"
                       @onchange="e => Fp.Passengers[idx].Name = e.Value?.ToString() ?? string.Empty"/>
            </td>
            <td>
                <input type="number" step="0.1" class="form-control form-control-sm"
                       @bind="Fp.Passengers[idx].WeightKg"
                       @bind:culture="System.Globalization.CultureInfo.InvariantCulture"/>
            </td>
            <td>
                <button class="btn btn-sm btn-outline-danger" @onclick="() => RemovePassenger(idx)">✕</button>
            </td>
        </tr>
    }
    </tbody>
    <tfoot>
    <tr>
        <td colspan="3">
            <button class="btn btn-sm btn-outline-success" @onclick="AddPassenger">+ Passagier toevoegen</button>
        </td>
    </tr>
    <tr class="table-secondary fw-bold">
        <td>Totaal gewicht</td>
        <td>@(CalcTotalWeight().ToString("F1")) kg</td>
        <td></td>
    </tr>
    </tfoot>
</table>

<div class="mt-2">
    @if (Fp.TotaalLiftKg.HasValue)
    {
        var liftOk = Fp.TotaalLiftKg.Value > CalcTotalWeight();
        var pct = Fp.TotaalLiftKg.Value > 0
            ? Math.Min(100, CalcTotalWeight() / Fp.TotaalLiftKg.Value * 100)
            : 0;
        <div class="mb-2">
            <div class="d-flex justify-content-between small mb-1">
                <span>Belading: @CalcTotalWeight().ToString("F1") kg / @Fp.TotaalLiftKg kg lift</span>
                <span class="fw-semibold">@pct.ToString("F0")%</span>
            </div>
            <div class="fp-load-bar-wrap">
                <div class="fp-load-bar @(liftOk ? "fp-load-bar-ok" : "fp-load-bar-warn")"
                     style="width:@pct.ToString("F0", CultureInfo.InvariantCulture)%"></div>
            </div>
        </div>
        @if (liftOk)
        {
            <span class="badge bg-success">✅ Lift voldoende</span>
        }
        else
        {
            <span class="badge bg-danger">❌ Lift onvoldoende</span>
        }
    }
</div>

<div class="mt-3">
    <label class="form-label">Notities</label>
    <textarea class="form-control" rows="3" @bind="Fp.LoadNotes"></textarea>
</div>
