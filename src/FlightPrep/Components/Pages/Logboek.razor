@page "/logboek"
@using FlightPrep.Domain.Models
@using FlightPrep.Domain.Services
@attribute [Authorize]
@rendermode InteractiveServer

<PageTitle>Logboek – FlightPrep</PageTitle>

@if (_flights == null)
{
    <div class="text-center py-5 text-muted"><em>Laden...</em></div>
}
else
{
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-start mb-4">
        <div>
            <h2 class="mb-1">📓 Logboek</h2>
            @if (_flights.Count > 0)
            {
                var first = _flights.First().Datum;
                var last = _flights.Last().Datum;
                <p class="text-muted mb-0">@first.ToString("dd/MM/yyyy") – @last.ToString("dd/MM/yyyy")</p>
            }
            else
            {
                <p class="text-muted mb-0">Geen vaarten gevonden</p>
            }
        </div>
        <a href="/flights/new" class="btn btn-primary btn-sm">+ Nieuwe Vaart</a>
    </div>

    <!-- Stats row 1 -->
    <div class="row g-3 mb-3">
        <div class="col-6 col-md-3">
            <div class="fp-stat-card">
                <div class="stat-number">@_totalFlights</div>
                <div class="stat-label">Totaal vaarten</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="fp-stat-card">
                <div class="stat-number">@_flownFlights</div>
                <div class="stat-label">Gevlogen vaarten</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="fp-stat-card">
                <div class="stat-number">@FormatMinutes(_totalMinutes)</div>
                <div class="stat-label">Totale vluchttijd</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="fp-stat-card">
                <div class="stat-number" style="font-size:1.1rem">@(_mostUsedLocation?.Key ?? "–")</div>
                <div class="stat-label">Meest gebruikte locatie</div>
            </div>
        </div>
    </div>

    <!-- Stats row 2 -->
    <div class="row g-3 mb-4">
        <div class="col-6 col-md-4">
            <div class="fp-stat-card">
                <div class="stat-number" style="font-size:1.1rem">@(_mostUsedBalloon?.Key ?? "–")</div>
                <div class="stat-label">Meest gebruikte ballon</div>
            </div>
        </div>
        <div class="col-6 col-md-4">
            <div class="fp-stat-card">
                <div class="stat-number">@_plannedFlights</div>
                <div class="stat-label">Vaarten gepland</div>
            </div>
        </div>
        <div class="col-6 col-md-4">
            <div class="fp-stat-card">
                <div class="stat-number">@(_flownFlights > 0 ? FormatMinutes(_totalMinutes / _flownFlights) : "–")</div>
                <div class="stat-label">Gem. vluchtduur</div>
            </div>
        </div>
    </div>

    <!-- Charts -->
    <div class="row g-3 mb-4">
        <div class="col-md-6">
            <div class="fp-card p-0 overflow-hidden h-100">
                <div class="fp-section-header">Vaarten per maand</div>
                <div class="p-3" style="height:260px">
                    <canvas id="chart-months"></canvas>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="fp-card p-0 overflow-hidden h-100">
                <div class="fp-section-header">Vaarten per locatie</div>
                <div class="p-3" style="height:260px">
                    <canvas id="chart-locations"></canvas>
                </div>
            </div>
        </div>
    </div>

    <!-- Flight list -->
    <div class="fp-card p-0 overflow-hidden">
        <div class="fp-section-header">Volledige vluchtenlijst</div>
        @if (!_flights.Any())
        {
            <div class="fp-empty-state">
                <div class="fp-empty-icon">🎈</div>
                <h5>Nog geen vaarten</h5>
                <p>Maak een nieuwe vaartvoorbereiding aan om te beginnen.</p>
                <a href="/flights/new" class="btn btn-primary">✈️ Eerste Vaart Aanmaken</a>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                    <tr>
                        <th>Datum</th>
                        <th>Locatie</th>
                        <th>Ballon</th>
                        <th>Piloot</th>
                        <th>Duur</th>
                        <th>Status</th>
                    </tr>
                    </thead>
                    <tbody>
                    @foreach (var f in _flights.OrderByDescending(f => f.Datum).ThenByDescending(f => f.Tijdstip))
                    {
                        <tr style="cursor:pointer" @onclick="() => Nav(f.Id)">
                            <td>@f.Datum.ToString("dd/MM/yyyy")</td>
                            <td>@(f.Location?.Name ?? "–")</td>
                            <td>@(f.Balloon?.Registration ?? "–")</td>
                            <td>@(f.Pilot?.Name ?? "–")</td>
                            <td>@(f.ActualFlightDurationMinutes.HasValue ? FormatMinutes(f.ActualFlightDurationMinutes.Value) : "–")</td>
                            <td>
                                @if (f.IsFlown)
                                {
                                    <span class="badge bg-success">Gevlogen</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Gepland</span>
                                }
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </div>
}

