@page "/release-notes"
@using System.Net
@using System.Text
@using FlightPrep.Domain.Models.ReleaseNotes
@using FlightPrep.Domain.Services
@rendermode InteractiveServer
@inject IReleaseNotesService ReleaseNotesSvc

<PageTitle>Release Notes – FlightPrep</PageTitle>

<div class="container-xl py-4">
    <div class="d-flex align-items-center gap-3 mb-2">
        <span style="font-size:2rem">📋</span>
        <div>
            <h1 class="mb-0">Release Notes</h1>
            <p class="text-muted mb-0 small">Overzicht van alle wijzigingen per pull request</p>
        </div>
        @if (!string.IsNullOrEmpty(_currentVersion))
        {
            <span class="badge ms-auto fs-6 px-3 py-2"
                  style="background:var(--fp-primary);font-family:monospace">
                v@(_currentVersion)
            </span>
        }
    </div>

    <div class="mb-4 small text-muted">
        <span class="badge bg-primary me-1">feature</span> major &nbsp;·&nbsp;
        <span class="badge bg-info text-dark me-1">refactor</span> minor &nbsp;·&nbsp;
        <span class="badge bg-danger me-1">bug</span> patch
    </div>

    @if (_entries == null)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
        </div>
    }
    else if (_entries.Count == 0)
    {
        <div class="alert alert-info">Nog geen release notes beschikbaar.</div>
    }
    else
    {
        <div class="release-timeline">
            @foreach (var entry in _entries)
            {
                <div class="release-entry card mb-4 shadow-sm border-0">
                    <div class="card-header d-flex align-items-center gap-2 flex-wrap py-3"
                         style="background:var(--fp-surface);border-bottom:1px solid var(--fp-border)">
                        <a href="https://github.com/NickThys3012/FlightPrep/pull/@(entry.Pr)"
                           target="_blank" rel="noopener"
                           class="badge text-decoration-none"
                           style="background:#1a3a5c;font-size:.85rem">
                            #@(entry.Pr)
                        </a>
                        @if (!string.IsNullOrEmpty(entry.Version))
                        {
                            <span class="badge border fw-normal"
                                  style="color:var(--fp-primary);border-color:var(--fp-primary)!important;font-family:monospace;font-size:.82rem">
                                v@(entry.Version)
                            </span>
                        }
                        <span class="fw-semibold flex-grow-1" style="font-size:1.05rem">@entry.Title</span>
                        @foreach (var label in entry.Labels)
                        {
                            <span class="badge @GetLabelClass(label)">@label</span>
                        }
                        <span class="text-muted small ms-auto">
                            <span title="@entry.Date.ToString("dd/MM/yyyy HH:mm")">
                                📅 @entry.Date.ToString("dd/MM/yyyy")
                            </span>
                            <span class="ms-1 text-muted fst-italic">(@GetRelativeDate(entry.Date))</span>
                        </span>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(entry.Description))
                    {
                        <div class="card-body py-3">
                            @((MarkupString)RenderDescription(entry.Description))
                        </div>
                    }
                    <div class="card-footer d-flex align-items-center gap-2 py-2"
                         style="background:transparent;border-top:1px solid var(--fp-border);font-size:.82rem">
                        <img src="@($"https://github.com/{entry.Author}.png?size=20")"
                             class="rounded-circle" width="20" height="20"
                             alt="@entry.Author"/>
                        <a href="https://github.com/@(entry.Author)" target="_blank" rel="noopener"
                           class="text-muted text-decoration-none">@@@(entry.Author)</a>
                        <a href="https://github.com/NickThys3012/FlightPrep/pull/@(entry.Pr)"
                           target="_blank" rel="noopener"
                           class="ms-auto text-decoration-none text-muted small">
                            Bekijk PR →
                        </a>
                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
    .release-timeline {
        max-width: 820px;
    }

    .release-entry {
        border-radius: 10px !important;
        overflow: hidden;
    }
</style>

@code {
    private List<ReleaseEntry>? _entries;
    private string _currentVersion = "";

    protected override async Task OnInitializedAsync()
    {
        var doc = await ReleaseNotesSvc.GetAsync();
        _entries = doc.Entries;
        _currentVersion = doc.CurrentVersion;
    }

    // Converts markdown-style description (intro line + "- bullet" lines) to HTML.
    private static string RenderDescription(string text)
    {
        var lines = text.Replace("\r\n", "\n").Split('\n');
        var html = new StringBuilder();
        var inList = false;

        foreach (var raw in lines)
        {
            var line = raw.Trim();
            if (string.IsNullOrEmpty(line)) continue;

            if (line.StartsWith("- ") || line.StartsWith("* "))
            {
                if (!inList)
                {
                    html.Append("<ul class=\"mb-0 ps-3\">");
                    inList = true;
                }

                html.Append($"<li>{WebUtility.HtmlEncode(line[2..])}</li>");
            }
            else
            {
                if (inList)
                {
                    html.Append("</ul>");
                    inList = false;
                }

                html.Append($"<p class=\"mb-2\">{WebUtility.HtmlEncode(line)}</p>");
            }
        }

        if (inList) html.Append("</ul>");
        return html.ToString();
    }

    private static string GetLabelClass(string label)
    {
        return label.ToLower() switch
        {
            "feature" or "enhancement" => "bg-primary",
            "bug" or "fix" or "bugfix" => "bg-danger",
            "docs" or "documentation" => "bg-success",
            "chore" or "maintenance" => "bg-secondary",
            "refactor" => "bg-info text-dark",
            "breaking" or "breaking change" => "bg-warning text-dark",
            _ => "bg-secondary"
        };
    }

    private static string GetRelativeDate(DateTime date)
    {
        var diff = DateTime.UtcNow - date.ToUniversalTime();
        if (diff.TotalDays < 1) return "vandaag";
        if (diff.TotalDays < 2) return "gisteren";
        if (diff.TotalDays < 7) return $"{(int)diff.TotalDays} dagen geleden";
        if (diff.TotalDays < 30) return $"{(int)(diff.TotalDays / 7)} weken geleden";
        if (diff.TotalDays < 365) return $"{(int)(diff.TotalDays / 30)} maanden geleden";
        return $"{(int)(diff.TotalDays / 365)} jaar geleden";
    }

}
