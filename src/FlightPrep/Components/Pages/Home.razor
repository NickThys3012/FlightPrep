@page "/"
@attribute [Authorize]
@rendermode InteractiveServer
@inject IFlightPreparationService FpSvc
@inject IGoNoGoService GoNoGoSvc
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>FlightPrep – Dashboard</PageTitle>

<!-- Hero -->
<div class="fp-hero">
    <h1>🎈 Welkom bij FlightPrep</h1>
    <p class="lead">Vaartvoorbereiding voor ballonvluchten — professioneel en overzichtelijk.</p>
    <div class="d-flex gap-2 mt-3">
        <a href="/flights/new" class="btn btn-light fw-semibold">✈️ Nieuwe Vaart</a>
        <a href="/flights" class="btn btn-outline-light">📋 Bekijk Vaarten</a>
    </div>
</div>

<!-- Stats row -->
<div class="row g-3 mb-4">
    <div class="col-sm-4">
        <div class="fp-stat-card">
            <div class="stat-number">@totalFlights</div>
            <div class="stat-label">Totaal Vaarten</div>
        </div>
    </div>
    <div class="col-sm-4">
        <div class="fp-stat-card">
            <div class="stat-number">@flightsThisYear</div>
            <div class="stat-label">Dit Jaar</div>
        </div>
    </div>
    <div class="col-sm-4">
        <div class="fp-stat-card">
            <div class="stat-number">@flightsFlown</div>
            <div class="stat-label">Gevlogen</div>
        </div>
    </div>
</div>

<!-- Recent flights -->
<div class="fp-card p-0 overflow-hidden">
    <div class="fp-section-header d-flex justify-content-between align-items-center">
        <span>Recente Vaarten</span>
        <a href="/flights" class="btn btn-sm btn-outline-light">Alle vaarten →</a>
    </div>
    <div class="p-3">
        @if (recentFlights == null)
        {
            <p class="text-muted"><em>Laden...</em></p>
        }
        else if (!recentFlights.Any())
        {
            <div class="fp-empty-state">
                <div class="fp-empty-icon">🎈</div>
                <h5>Nog geen vaarten</h5>
                <p>Maak een nieuwe vaartvoorbereiding aan om te beginnen.</p>
                <a href="/flights/new" class="btn btn-primary">✈️ Eerste Vaart Aanmaken</a>
            </div>
        }
        else
        {
            <div class="list-group list-group-flush">
                @foreach (var f in recentFlights)
                {
                    <a href="/flights/@f.Id" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center py-3">
                        <div>
                            <div class="fw-semibold">@f.Datum.ToString("dd/MM/yyyy") @f.Tijdstip.ToString("HH:mm")</div>
                            <div class="text-muted small">
                                @(f.Balloon?.Registration ?? "–") &nbsp;·&nbsp;
                                @(f.Pilot?.Name ?? "–") &nbsp;·&nbsp;
                                @(f.Location?.Name ?? "–")
                            </div>
                        </div>
                        <div class="d-flex gap-2 align-items-center">
                            <FlightGoNoGoBadge GoNoGoResult="@GoNoGoSvc.Compute(f, _goNoGoSettings)" />
                            @if (f.IsFlown)
                            {
                                <span class="badge bg-success">Gevlogen</span>
                            }
                        </div>
                    </a>
                }
            </div>
        }
    </div>
</div>

@code {
    private int totalFlights;
    private int flightsThisYear;
    private int flightsFlown;
    private List<FlightPreparation>? recentFlights;
    private GoNoGoSettings _goNoGoSettings = new();

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var userId = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;

        _goNoGoSettings = await GoNoGoSvc.GetSettingsAsync(userId);

        var (total, thisYear, flown) = await FpSvc.GetFlightCountsAsync();
        totalFlights    = total;
        flightsThisYear = thisYear;
        flightsFlown    = flown;

        recentFlights = await FpSvc.GetRecentAsync(5);
    }
}
