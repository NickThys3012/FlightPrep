@page "/admin/users"
@using FlightPrep.Infrastructure.Data
@using Microsoft.AspNetCore.Identity
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Admin")]
@inject UserManager<ApplicationUser> UserManager
@inject ILogger<UserManagement> Logger
@inject AuthenticationStateProvider AuthStateProvider
@inject IDbContextFactory<AppDbContext> DbFactory

<PageTitle>User Management</PageTitle>
<h1>User Management</h1>

@if (_errorMessage != null)
{
    <div class="alert alert-danger">@_errorMessage</div>
}

<ul class="nav nav-tabs mb-3">
    <li class="nav-item">
        <button class="nav-link @(_activeTab == "users" ? "active" : "")" @onclick='() => _activeTab = "users"'>Users
        </button>
    </li>
    <li class="nav-item">
        <button class="nav-link @(_activeTab == "loginhistory" ? "active" : "")"
                @onclick='() => _activeTab = "loginhistory"'>Login History
        </button>
    </li>
</ul>

@if (_activeTab == "users")
{
    @if (_users == null)
    {
        <p>Loading…</p>
    }
    else
    {
        <table class="table table-striped">
            <thead>
            <tr>
                <th>Email</th>
                <th>Roles</th>
                <th>Approved</th>
                <th>Actions</th>
            </tr>
            </thead>
            <tbody>
            @foreach (var u in _users)
            {
                <tr>
                    <td>@u.Email</td>
                    <td>@string.Join(", ", u.Roles)</td>
                    <td>@(u.IsApproved ? "✅" : "⏳")</td>
                    <td>
                        @if (!u.IsApproved)
                        {
                            <button class="btn btn-sm btn-success" @onclick="() => ApproveUser(u.Id)">Approve</button>
                        }
                        <button class="btn btn-sm btn-danger" @onclick="() => DeleteUser(u.Id)">Delete</button>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    }
}

@if (_activeTab == "loginhistory")
{
    @if (_loginEvents == null)
    {
        <p>Loading…</p>
    }
    else if (!_loginEvents.Any())
    {
        <p class="text-muted">No login events recorded yet.</p>
    }
    else
    {
        <table class="table table-striped table-sm">
            <thead>
            <tr>
                <th>Timestamp</th>
                <th>Email</th>
                <th>Success</th>
                <th>Failure Reason</th>
                <th>IP Address</th>
            </tr>
            </thead>
            <tbody>
            @foreach (var e in _loginEvents)
            {
                <tr>
                    <td>@e.Timestamp.ToLocalTime().ToString("dd/MM/yyyy HH:mm:ss")</td>
                    <td>@e.Email</td>
                    <td>@(e.Success ? "✅" : "❌")</td>
                    <td>@(e.FailureReason ?? "–")</td>
                    <td>@(e.IpAddress ?? "–")</td>
                </tr>
            }
            </tbody>
        </table>
    }
}
