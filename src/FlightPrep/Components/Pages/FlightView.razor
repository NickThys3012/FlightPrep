@page "/flights/{Id:int}"
@using System.Text.Json
@using FlightPrep.Domain.Models
@using FlightPrep.Domain.Models.Trajectory
@using FlightPrep.Domain.Services
@attribute [Authorize]
@rendermode InteractiveServer
@inject IFlightPreparationService FpSvc
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Nav
@inject IFlightAssessmentService AssessmentSvc
@inject IPdfService PdfSvc
@inject ISunriseService SunriseSvc
@inject IJSRuntime Js
@inject IKmlService KmlSvc
@inject ILogger<FlightView> Logger
@inject IOFPSettingsService OfpSettingsSvc

<PageTitle>Vaart Bekijken – FlightPrep</PageTitle>

@if (_fp == null)
{
    <p><em>Laden...</em></p>
}
else
{
    <div class="container-fluid mt-3">
        @if (_fp.IsFlown)
        {
            <div class="fp-flown-banner">
                ✈️ Deze vaart is gevlogen
            </div>
        }

        <div class="fp-page-header">
            <div>
                <h2 class="mb-1">
                    @_fp.Datum.ToString("dd MMMM yyyy") &nbsp;
                    <span class="text-muted fw-normal fs-5">@_fp.Tijdstip.ToString("HH:mm")</span>
                </h2>
                @{ var gng = _assessment?.GoNoGo ?? "unknown"; }
                <FlightGoNoGoBadge GoNoGoResult="@gng" ShowEmoji="true"/>
            </div>
            <div class="fp-toolbar">
                <a href="/flights/@_fp.Id/edit" class="btn btn-outline-secondary">Bewerken</a>
                <button class="btn btn-success" @onclick="DownloadPdf">Download PDF</button>
                <button class="btn btn-outline-primary" @onclick="DownloadOfp">
                    <i class="bi bi-file-earmark-text"></i> Download OFP
                </button>
                <button class="btn btn-outline-primary" @onclick="() => _showFlownModal = true">Markeer als gevlogen
                </button>
                <a href="/flights" class="btn btn-outline-secondary">Terug</a>
            </div>
        </div>

        <div class="row g-3">
            <!-- Section 1 -->
            <div class="col-12">
                <div class="card">
                    <div class="card-header bg-primary text-white">1. Algemene Gegevens</div>
                    <div class="card-body">
                        <dl class="row mb-0">
                            <dt class="col-sm-3">Datum</dt>
                            <dd class="col-sm-9">@_fp.Datum.ToString("dd/MM/yyyy")</dd>
                            <dt class="col-sm-3">Tijdstip</dt>
                            <dd class="col-sm-9">@_fp.Tijdstip.ToString("HH:mm") LT</dd>
                            <dt class="col-sm-3">Ballon</dt>
                            <dd class="col-sm-9">@(_fp.Balloon != null ? $"{_fp.Balloon.Registration} – {_fp.Balloon.Type} ({(_fp.Balloon.VolumeM3.HasValue ? $"{_fp.Balloon.VolumeM3:F0} m³" : "–")})" : "–")</dd>
                            <dt class="col-sm-3">Piloot / PIC</dt>
                            <dd class="col-sm-9">@(_fp.Pilot?.Name ?? "–")</dd>
                            <dt class="col-sm-3">Locatie</dt>
                            <dd class="col-sm-9">@(_fp.Location?.Name ?? "–")</dd>
                            <dt class="col-sm-3">Veld eigenaar gemeld</dt>
                            <dd class="col-sm-9">
                                @if (_fp.VeldEigenaarGemeld)
                                {
                                    <span class="badge bg-success">Ja</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Nee / NVT</span>
                                    <a href="https://forms.monday.com/forms/90b13ba3fa8356c3f9a6d5f46b10421a?r=euc1"
                                       target="_blank" rel="noopener" class="ms-2 small">formulier invullen</a>
                                }
                            </dd>
                        </dl>
                        @if (_sunriseSunset.HasValue)
                        {
                            <div class="fp-sun-card">
                                <span>🌅 Zonsopgang: <strong>@_sunriseSunset.Value.Sunrise.ToString("HH:mm") UTC</strong></span>
                                <span>🌇 Zonsondergang: <strong>@_sunriseSunset.Value.Sunset.ToString("HH:mm") UTC</strong></span>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- Section 2 -->
            <div class="col-12">
                <div class="card">
                    <div class="card-header bg-primary text-white">2. Meteorologische Informatie</div>
                    <div class="card-body">
                        <dl class="row mb-0">
                            <dt class="col-sm-3">METAR</dt>
                            <dd class="col-sm-9 font-monospace">@(_fp.Metar ?? "–")</dd>
                            <dt class="col-sm-3">TAF</dt>
                            <dd class="col-sm-9 font-monospace" style="white-space:pre-wrap">@(_fp.Taf ?? "–")</dd>
                            <dt class="col-sm-3">Wind per hoogte</dt>
                            <dd class="col-sm-9" style="white-space:pre-wrap">@(_fp.WindPerHoogte ?? "–")</dd>
                            <dt class="col-sm-3">Neerslag / bewolking</dt>
                            <dd class="col-sm-9">@(_fp.Neerslag ?? "–")</dd>
                            <dt class="col-sm-3">Windrichting oppervlak</dt>
                            <dd class="col-sm-9">@(_fp.SurfaceWindDirectionDeg.HasValue ? $"{_fp.SurfaceWindDirectionDeg}°" : "–")</dd>
                            <dt class="col-sm-3">Windsnelheid oppervlak</dt>
                            <dd class="col-sm-9">@(_fp.SurfaceWindSpeedKt.HasValue ? $"{_fp.SurfaceWindSpeedKt} kt" : "–")</dd>
                            <dt class="col-sm-3">Temperatuur</dt>
                            <dd class="col-sm-9">@(_fp.TemperatuurC.HasValue ? $"{_fp.TemperatuurC}°C" : "–")</dd>
                            <dt class="col-sm-3">Dauwpunt</dt>
                            <dd class="col-sm-9">@(_fp.DauwpuntC.HasValue ? $"{_fp.DauwpuntC}°C" : "–")</dd>
                            <dt class="col-sm-3">QNH</dt>
                            <dd class="col-sm-9">@(_fp.QnhHpa.HasValue ? $"{_fp.QnhHpa} hPa" : "–")</dd>
                            <dt class="col-sm-3">Zichtbaarheid</dt>
                            <dd class="col-sm-9">@(_fp.ZichtbaarheidKm.HasValue ? $"{_fp.ZichtbaarheidKm} km" : "–")</dd>
                            <dt class="col-sm-3">CAPE</dt>
                            <dd class="col-sm-9">@(_fp.CapeJkg.HasValue ? $"{_fp.CapeJkg} J/kg" : "–")</dd>
                        </dl>
                        @if (_fp.WindLevels.Count > 0)
                        {
                            <table class="table table-sm table-bordered mt-3">
                                <thead class="table-light">
                                <tr>
                                    <th>Hoogte (ft)</th>
                                    <th>Richting (°)</th>
                                    <th>Snelheid (kt)</th>
                                    <th>Temp (°C)</th>
                                </tr>
                                </thead>
                                <tbody>
                                @foreach (var wl in _fp.WindLevels.OrderBy(w => w.Order))
                                {
                                    <tr>
                                        <td>@wl.AltitudeFt</td>
                                        <td>@(wl.DirectionDeg?.ToString() ?? "–")</td>
                                        <td>@(wl.SpeedKt?.ToString() ?? "–")</td>
                                        <td>@(wl.TempC?.ToString("F1") ?? "–")</td>
                                    </tr>
                                }
                                </tbody>
                            </table>
                        }
                        @{ var meteo = _fp.Images.Where(i => i.Section == "Meteo").ToList(); }
                        @if (meteo.Count > 0)
                        {
                            <div class="fp-thumb-grid">
                                @foreach (var img in meteo)
                                {
                                    <img src="data:@img.ContentType;base64,@Convert.ToBase64String(img.Data)"
                                         class="flight-thumb"
                                         title="@img.FileName"
                                         @onclick="() => OpenLightbox(img)"/>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- Section 3 -->
            <div class="col-md-6">
                <div class="card h-100">
                    <div class="card-header bg-primary text-white">3. Luchtruim en NOTAMs</div>
                    <div class="card-body">
                        <dl class="row mb-0">
                            <dt class="col-sm-5">NOTAMs gecontroleerd</dt>
                            <dd class="col-sm-7">@_fp.NotamsGecontroleerd</dd>
                            <dt class="col-sm-5">Luchtruimstructuur</dt>
                            <dd class="col-sm-7" style="white-space:pre-wrap">@(_fp.Luchtruimstructuur ?? "–")</dd>
                            <dt class="col-sm-5">Beperkingen</dt>
                            <dd class="col-sm-7" style="white-space:pre-wrap">@(_fp.Beperkingen ?? "–")</dd>
                            <dt class="col-sm-5">Obstakels</dt>
                            <dd class="col-sm-7" style="white-space:pre-wrap">@(_fp.Obstakels ?? "–")</dd>
                        </dl>
                    </div>
                </div>
            </div>

            <!-- Section 4 -->
            <div class="col-md-6">
                <div class="card h-100">
                    <div class="card-header bg-primary text-white">4. Veiligheid en Communicatie</div>
                    <div class="card-body">
                        <dl class="row mb-0">
                            <dt class="col-sm-7">EHBO-kit en vuurblusser</dt>
                            <dd class="col-sm-5">@_fp.EhboEnBlusser</dd>
                            <dt class="col-sm-7">Passagierslijst ingevuld</dt>
                            <dd class="col-sm-5">@_fp.PassagierslijstIngevuld</dd>
                            <dt class="col-sm-7">Vluchtplan ingediend</dt>
                            <dd class="col-sm-5">@_fp.VluchtplanIngediend</dd>
                        </dl>
                    </div>
                </div>
            </div>

            <!-- Section 5 -->
            <div class="col-md-6">
                <div class="card h-100">
                    <div class="card-header bg-primary text-white">5. Technische Controle</div>
                    <div class="card-body">
                        <ul class="list-unstyled mb-0">
                            <li>@(_fp.BranderGetest ? "☑" : "☐") Brander getest</li>
                            <li>@(_fp.GasflaconsGecontroleerd ? "☑" : "☐") Gasflessen gevuld &amp; gecontroleerd</li>
                            <li>@(_fp.BallonVisueel ? "☑" : "☐") Ballon en mand visueel geïnspecteerd</li>
                            <li>@(_fp.VerankeringenGecontroleerd ? "☑" : "☐") Verankeringen en touwen gecontroleerd</li>
                            <li>@(_fp.InstrumentenWerkend ? "☑" : "☐") Instrumenten werkend</li>
                        </ul>
                    </div>
                </div>
            </div>

            <!-- Section 7 -->
            <div class="col-md-6">
                <div class="card h-100">
                    <div class="card-header bg-primary text-white">7. Load Berekening</div>
                    <div class="card-body">
                        <p><strong>Gewicht envelop:</strong> @(_fp.EnvelopeWeightKg?.ToString("F1") ?? "–") kg</p>
                        <p><strong>Max
                                Altitude:</strong> @(_fp.MaxAltitudeFt.HasValue ? _fp.MaxAltitudeFt + " ft" : "–")</p>
                        <p><strong>Totaal lift:</strong> @(_fp.TotaalLiftKg?.ToString("F1") ?? "–") kg</p>
                        <table class="table table-sm">
                            <thead>
                            <tr>
                                <th>Naam</th>
                                <th>Gewicht</th>
                            </tr>
                            </thead>
                            <tbody>
                            <tr class="table-light">
                                <td><em>Piloot: @(_fp.Pilot?.Name ?? "–")</em></td>
                                <td>@(_fp.Pilot?.WeightKg?.ToString("F1") ?? "–") kg</td>
                            </tr>
                            @foreach (var p in _fp.Passengers.OrderBy(x => x.Order))
                            {
                                <tr>
                                    <td>@p.Name</td>
                                    <td>@p.WeightKg.ToString("F1") kg</td>
                                </tr>
                            }
                            <tr class="fw-bold table-secondary">
                                <td>Totaal</td>
                                <td>@(_assessment?.TotaalGewicht.ToString("F1") ?? "–") kg</td>
                            </tr>
                            </tbody>
                        </table>
                        @if (_fp.TotaalLiftKg.HasValue)
                        {
                            <span class="badge @(_assessment?.LiftVoldoende ?? false ? "bg-success" : "bg-danger")">
                                @(_assessment?.LiftVoldoende ?? false ? "✅ Lift voldoende" : "❌ Lift onvoldoende")
                            </span>
                        }
                    </div>
                </div>
            </div>

            <!-- Section 6 -->
            <div class="col-12">
                <div class="card">
                    <div class="card-header bg-primary text-white">6. Pax Briefing</div>
                    <div class="card-body p-0">
                        <div class="ql-snow">
                            <div class="ql-editor">@((MarkupString)(_fp.PaxBriefing ?? "<em>–</em>"))</div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Section 8 -->
            <div class="col-12">
                <div class="card">
                    <div class="card-header bg-primary text-white">8. Traject</div>
                    <div class="card-body">
                        @{
                            var hasSavedEnh = _savedEnhancedTrajectories != null && _savedEnhancedTrajectories.Any(t => t.Points.Count > 0);
                            var hasSavedDr = _savedTrajectories is { Count: > 0 };
                        }
                        @if ((hasSavedEnh || hasSavedDr) && _fp?.Location?.Latitude != null)
                        {
                            <div class="mb-3">
                                <div class="d-flex flex-wrap gap-1 align-items-center mb-2">
                                    @foreach (var t in (_savedEnhancedTrajectories ?? []).Where(t => t.Points.Count > 0))
                                    {
                                        <span class="badge"
                                              style="background-color:@t.Color">@t.AltitudeFt ft (3D)</span>
                                    }
                                    @foreach (var t in _savedTrajectories ?? [])
                                    {
                                        <span class="badge"
                                              style="background-color:@t.Color">@t.AltitudeFt ft (DR)</span>
                                    }
                                    @{
                                        var refTraj = (_savedEnhancedTrajectories ?? []).FirstOrDefault(t => t.Points.Count > 0)
                                                          ?? _savedTrajectories?.FirstOrDefault();
                                    }
                                    @if (refTraj != null)
                                    {
                                        <span class="text-muted small ms-2">
                                            @refTraj.DurationMinutes min —
                                            @refTraj.SimulatedAt.ToString("dd/MM/yyyy HH:mm")
                                        </span>
                                    }
                                </div>
                                <div id="saved-combined-map"
                                     style="height:400px;border-radius:8px;overflow:hidden;"></div>
                            </div>
                        }
                        @if (!string.IsNullOrWhiteSpace(_fp?.Traject))
                        {
                            <pre class="mb-3">@_fp.Traject</pre>
                        }
                        @{ var traj = _fp?.Images.Where(i => i.Section == "Traject").ToList(); }
                        @if (traj is { Count: > 0 })
                        {
                            <div class="fp-thumb-grid">
                                @foreach (var img in traj)
                                {
                                    <img src="data:@img.ContentType;base64,@Convert.ToBase64String(img.Data)"
                                         class="flight-thumb"
                                         title="@img.FileName"
                                         @onclick="() => OpenLightbox(img)"/>
                                }
                            </div>
                        }
                        @if (string.IsNullOrWhiteSpace(_fp?.Traject) && traj is { Count: 0 })
                        {
                            <span class="text-muted">–</span>
                        }
                    </div>
                </div>
            </div>

            <!-- Section 9 -->
            <div class="col-12 mb-4">
                <div class="card">
                    <div class="card-header bg-primary text-white">9. Ballonbulletin</div>
                    <div class="card-body">
                        <pre class="font-monospace small mb-0">@_fp?.Ballonbulletin</pre>
                    </div>
                </div>
            </div>

            @if (_fp is { IsFlown: true })
            {
                <div class="col-12 mb-4">
                    <div class="card border-success">
                        <div class="card-header bg-success text-white">✈️ Vluchtverslag</div>
                        <div class="card-body">
                            <dl class="row mb-0">
                                <dt class="col-sm-3">Werkelijke landing</dt>
                                <dd class="col-sm-9">@(_fp.ActualLandingNotes ?? "–")</dd>
                                <dt class="col-sm-3">Vluchtduur</dt>
                                <dd class="col-sm-9">@(_fp.ActualFlightDurationMinutes.HasValue ? $"{_fp.ActualFlightDurationMinutes} min" : "–")</dd>
                                <dt class="col-sm-3">Opmerkingen</dt>
                                <dd class="col-sm-9" style="white-space:pre-wrap">@(_fp.ActualRemarks ?? "–")</dd>
                            </dl>
                        </div>
                    </div>
                </div>
            }

            <!-- Section: Vlucht Track -->
            <div class="col-12 mt-3">
                <div class="card">
                    <div class="card-header d-flex justify-content-between align-items-center"
                         style="background:#1a3a5c;color:white;">
                        <span>Vlucht Track</span>
                        <button class="btn btn-sm btn-outline-light"
                                @onclick="() => _showTrackUpload = !_showTrackUpload">
                            @(_fp!.KmlTrack != null ? "Vervangen" : "KML Uploaden")
                        </button>
                    </div>
                    <div class="card-body p-0">
                        @if (_showTrackUpload || _fp!.KmlTrack == null)
                        {
                            <div class="p-3">
                                <p class="text-muted small mb-2">Upload een KML bestand van de Hot Air app (of ander GPS
                                    logger). Het track wordt op een kaart weergegeven.</p>
                                <InputFile OnChange="OnKmlUpload" accept=".kml" class="form-control form-control-sm"/>
                                @if (_kmlUploadError != null)
                                {
                                    <div class="alert alert-danger mt-2 py-1 small">@_kmlUploadError</div>
                                }
                            </div>
                        }

                        @if (_trackPoints is { Count: > 0 })
                        {
                            var stats = KmlSvc.ComputeStats(_trackPoints);
                            <div class="d-flex gap-4 px-3 pt-3 pb-2 flex-wrap">
                                <div class="text-center">
                                    <div class="fw-bold fs-5">@((stats.MaxAltM * 3.28084).ToString("F0")) ft</div>
                                    <div class="text-muted small">Max hoogte</div>
                                </div>
                                <div class="text-center">
                                    <div class="fw-bold fs-5">@((stats.MinAltM * 3.28084).ToString("F0")) ft</div>
                                    <div class="text-muted small">Min hoogte</div>
                                </div>
                                <div class="text-center">
                                    <div class="fw-bold fs-5">@stats.DistanceKm.ToString("F1") km</div>
                                    <div class="text-muted small">Afstand</div>
                                </div>
                                <div class="text-center">
                                    <div class="fw-bold fs-5">@_trackPoints.Count</div>
                                    <div class="text-muted small">GPS punten</div>
                                </div>
                            </div>
                            <div id="flight-track-map" style="height:520px;width:100%;"></div>
                            <div class="px-3 pt-3 pb-2">
                                <div class="fw-semibold small text-muted mb-1">Hoogteprofiel</div>
                                <div style="height:180px;position:relative;">
                                    <canvas id="altitude-chart"></canvas>
                                </div>
                            </div>
                        }
                        else if (_fp!.KmlTrack == null)
                        {
                            <div class="p-3 text-muted small">Nog geen track geüpload.</div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<!-- Mark as flown modal -->
@if (_showFlownModal)
{
    <div class="modal d-block" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Markeer als gevlogen</h5>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Werkelijke landing</label>
                        <input type="text" class="form-control" @bind="_flownLandingNotes"/>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Vluchtduur (min)</label>
                        <input type="number" class="form-control" @bind="_flownDurationMinutes"/>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Opmerkingen</label>
                        <textarea class="form-control" rows="3" @bind="_flownRemarks"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-success" @onclick="SaveFlown">Opslaan</button>
                    <button class="btn btn-secondary" @onclick="() => _showFlownModal = false">Annuleren</button>
                </div>
            </div>
        </div>
    </div>
    <div class="modal-backdrop fade show"></div>
}

<!-- Lightbox modal -->
@if (_lightboxImg != null)
{
    <div class="lightbox-backdrop" @onclick="CloseLightbox">
        <div class="lightbox-content" @onclick:stopPropagation="true">
            <button class="lightbox-close" @onclick="CloseLightbox">&times;</button>
            <img src="data:@_lightboxImg.ContentType;base64,@Convert.ToBase64String(_lightboxImg.Data)"
                 alt="@_lightboxImg.FileName" class="lightbox-img"/>
            <div class="lightbox-caption">@_lightboxImg.FileName</div>
        </div>
    </div>
}
