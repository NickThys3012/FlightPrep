@page "/flights/new"
@page "/flights/{Id:int}/edit"
@rendermode InteractiveServer
@inject IDbContextFactory<AppDbContext> DbFactory
@inject NavigationManager Nav
@inject WeatherService WeatherSvc
@inject PdfService PdfSvc
@inject IJSRuntime JS
@using Microsoft.AspNetCore.Components.Forms

<PageTitle>@(Id.HasValue ? "Vaart Bewerken" : "Nieuwe Vaart") – FlightPrep</PageTitle>

<div class="container-fluid mt-3">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>@(Id.HasValue ? "✏️ Vaart Bewerken" : "➕ Nieuwe Vaart")</h2>
        <a href="/flights" class="btn btn-outline-secondary">← Terug</a>
    </div>

    @if (fp == null)
    {
        <p><em>Laden...</em></p>
    }
    else
    {
        <div class="accordion" id="flightAccordion">

            <!-- SECTION 1: Algemene Gegevens -->
            <div class="accordion-item">
                <h2 class="accordion-header">
                    <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#sec1">
                        1. Algemene Gegevens
                    </button>
                </h2>
                <div id="sec1" class="accordion-collapse collapse show">
                    <div class="accordion-body">
                        <div class="row g-3">
                            <div class="col-md-3">
                                <label class="form-label">Datum</label>
                                <input type="date" class="form-control" value="@fp.Datum.ToString("yyyy-MM-dd")"
                                    @onchange="e => fp.Datum = DateOnly.Parse(e.Value!.ToString()!)" />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">Tijdstip (LT)</label>
                                <input type="time" class="form-control" value="@fp.Tijdstip.ToString("HH:mm")"
                                    @onchange="e => fp.Tijdstip = TimeOnly.Parse(e.Value!.ToString()!)" />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">Ballon</label>
                                <select class="form-select" @bind="fp.BalloonId" @bind:after="OnBalloonChanged">
                                    <option value="">– Selecteer ballon –</option>
                                    @foreach (var b in balloons)
                                    {
                                        <option value="@b.Id">@b.Registration – @b.Type (@b.Volume)</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">Piloot / PIC</label>
                                <select class="form-select" @bind="fp.PilotId" @bind:after="OnPilotChanged">
                                    <option value="">– Selecteer piloot –</option>
                                    @foreach (var p in pilots)
                                    {
                                        <option value="@p.Id">@p.Name</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Locatie</label>
                                <select class="form-select" @bind="fp.LocationId" @bind:after="OnLocationChanged">
                                    <option value="">– Selecteer locatie –</option>
                                    @foreach (var l in locations)
                                    {
                                        <option value="@l.Id">@l.Name @(l.IcaoCode != null ? $"({l.IcaoCode})" : "")</option>
                                    }
                                </select>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- SECTION 2: Meteorologische Informatie -->
            <div class="accordion-item">
                <h2 class="accordion-header">
                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#sec2">
                        2. Meteorologische Informatie
                    </button>
                </h2>
                <div id="sec2" class="accordion-collapse collapse">
                    <div class="accordion-body">
                        <div class="mb-3">
                            <button class="btn btn-info" @onclick="FetchWeather" disabled="@fetchingWeather">
                                @if (fetchingWeather)
                                {
                                    <span class="spinner-border spinner-border-sm me-1"></span>
                                    <span>Ophalen...</span>
                                }
                                else
                                {
                                    <span>🌤️ Haal METAR/TAF Op</span>
                                }
                            </button>
                            @if (weatherError != null)
                            {
                                <span class="text-danger ms-3">@weatherError</span>
                            }
                            @if (weatherSuccess)
                            {
                                <span class="text-success ms-3">✅ METAR/TAF opgehaald!</span>
                            }
                        </div>
                        <div class="row g-3">
                            <div class="col-12">
                                <label class="form-label">METAR</label>
                                <textarea class="form-control font-monospace" rows="3" @bind="fp.Metar"></textarea>
                            </div>
                            <div class="col-12">
                                <label class="form-label">TAF</label>
                                <textarea class="form-control font-monospace" rows="5" @bind="fp.Taf"></textarea>
                            </div>
                            <div class="col-12">
                                <label class="form-label">Windrichting/-snelheid per hoogte</label>
                                <textarea class="form-control" rows="3" @bind="fp.WindPerHoogte"></textarea>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Neerslagkans / bewolking</label>
                                <input type="text" class="form-control" @bind="fp.Neerslag" />
                            </div>
                            <div class="col-md-2">
                                <label class="form-label">Temperatuur (°C)</label>
                                <input type="number" step="0.1" class="form-control" @bind="fp.TemperatuurC" />
                            </div>
                            <div class="col-md-2">
                                <label class="form-label">Dauwpunt (°C)</label>
                                <input type="number" step="0.1" class="form-control" @bind="fp.DauwpuntC" />
                            </div>
                            <div class="col-md-2">
                                <label class="form-label">QNH (hPa)</label>
                                <input type="number" step="0.1" class="form-control" @bind="fp.QnhHpa" />
                            </div>
                            <div class="col-md-2">
                                <label class="form-label">Zichtbaarheid (km)</label>
                                <input type="number" step="0.1" class="form-control" @bind="fp.ZichtbaarheidKm" />
                            </div>
                            <div class="col-md-2">
                                <label class="form-label">CAPE (J/kg)</label>
                                <input type="number" step="1" class="form-control" @bind="fp.CapeJkg" />
                            </div>

                            <!-- Image upload – Meteo -->
                            <div class="col-12 mt-2">
                                <label class="form-label fw-semibold">📷 Foto's (sonde, sounding, skew-T, ...)</label>
                                <InputFile OnChange="UploadMeteoImages" multiple accept="image/*"
                                    class="form-control" />
                                @if (meteoImages.Count > 0)
                                {
                                    <div class="d-flex flex-wrap gap-2 mt-2">
                                        @foreach (var img in meteoImages)
                                        {
                                            <div class="position-relative" style="width:140px">
                                                <img src="data:@img.ContentType;base64,@Convert.ToBase64String(img.Data)"
                                                    class="img-thumbnail" style="width:140px;height:105px;object-fit:cover" />
                                                <span class="position-absolute top-0 end-0 p-1 text-truncate w-100 small text-muted"
                                                    style="font-size:.65rem;background:rgba(255,255,255,.8)">@img.FileName</span>
                                                <button type="button" class="btn btn-danger btn-sm position-absolute top-0 start-0"
                                                    style="padding:1px 5px;font-size:.7rem"
                                                    @onclick="() => RemoveImage(img)">✕</button>
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- SECTION 3: Luchtruim en NOTAMs -->
            <div class="accordion-item">
                <h2 class="accordion-header">
                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#sec3">
                        3. Luchtruim en NOTAMs
                    </button>
                </h2>
                <div id="sec3" class="accordion-collapse collapse">
                    <div class="accordion-body">
                        <div class="row g-3">
                            <div class="col-md-3">
                                <label class="form-label">NOTAMs gecontroleerd</label>
                                <select class="form-select" @bind="fp.NotamsGecontroleerd">
                                    <option value="JA">JA</option>
                                    <option value="NEE">NEE</option>
                                </select>
                            </div>
                            <div class="col-12">
                                <label class="form-label">Luchtruimstructuur</label>
                                <textarea class="form-control" rows="3" @bind="fp.Luchtruimstructuur"></textarea>
                            </div>
                            <div class="col-12">
                                <label class="form-label">Beperkingen / gesloten zones</label>
                                <textarea class="form-control" rows="3" @bind="fp.Beperkingen"></textarea>
                            </div>
                            <div class="col-12">
                                <label class="form-label">Obstakels</label>
                                <textarea class="form-control" rows="2" @bind="fp.Obstakels"></textarea>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- SECTION 4: Veiligheid en Communicatie -->
            <div class="accordion-item">
                <h2 class="accordion-header">
                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#sec4">
                        4. Veiligheid en Communicatie
                    </button>
                </h2>
                <div id="sec4" class="accordion-collapse collapse">
                    <div class="accordion-body">
                        <div class="row g-3">
                            <div class="col-md-4">
                                <label class="form-label">EHBO-kit en vuurblusser</label>
                                <select class="form-select" @bind="fp.EhboEnBlusser">
                                    <option value="JA">JA</option>
                                    <option value="NEE">NEE</option>
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Passagierslijst ingevuld</label>
                                <select class="form-select" @bind="fp.PassagierslijstIngevuld">
                                    <option value="JA">JA</option>
                                    <option value="NEE">NEE</option>
                                    <option value="NVT">NVT</option>
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Vluchtplan ingediend</label>
                                <select class="form-select" @bind="fp.VluchtplanIngediend">
                                    <option value="JA">JA</option>
                                    <option value="NEE">NEE</option>
                                    <option value="NVT">NVT</option>
                                </select>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- SECTION 5: Technische Controle -->
            <div class="accordion-item">
                <h2 class="accordion-header">
                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#sec5">
                        5. Technische Controle
                    </button>
                </h2>
                <div id="sec5" class="accordion-collapse collapse">
                    <div class="accordion-body">
                        <div class="form-check mb-2">
                            <input class="form-check-input" type="checkbox" @bind="fp.BranderGetest" id="chk1" />
                            <label class="form-check-label" for="chk1">Brander getest</label>
                        </div>
                        <div class="form-check mb-2">
                            <input class="form-check-input" type="checkbox" @bind="fp.GasflaconsGecontroleerd" id="chk2" />
                            <label class="form-check-label" for="chk2">Gasflessen gevuld &amp; gecontroleerd</label>
                        </div>
                        <div class="form-check mb-2">
                            <input class="form-check-input" type="checkbox" @bind="fp.BallonVisueel" id="chk3" />
                            <label class="form-check-label" for="chk3">Ballon en mand visueel geïnspecteerd</label>
                        </div>
                        <div class="form-check mb-2">
                            <input class="form-check-input" type="checkbox" @bind="fp.VerankeringenGecontroleerd" id="chk4" />
                            <label class="form-check-label" for="chk4">Verankeringen en touwen gecontroleerd</label>
                        </div>
                        <div class="form-check mb-2">
                            <input class="form-check-input" type="checkbox" @bind="fp.InstrumentenWerkend" id="chk5" />
                            <label class="form-check-label" for="chk5">Instrumenten werkend</label>
                        </div>
                    </div>
                </div>
            </div>

            <!-- SECTION 6: Pax Briefing -->
            <div class="accordion-item">
                <h2 class="accordion-header">
                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse"
                        data-bs-target="#sec6" @onclick="InitQuillOnOpen">
                        6. Pax Briefing
                    </button>
                </h2>
                <div id="sec6" class="accordion-collapse collapse">
                    <div class="accordion-body">
                        <div id="pax-briefing-editor" style="min-height:300px"></div>
                    </div>
                </div>
            </div>

            <!-- SECTION 7: Load Calculation -->
            <div class="accordion-item">
                <h2 class="accordion-header">
                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#sec7">
                        7. Load Berekening
                    </button>
                </h2>
                <div id="sec7" class="accordion-collapse collapse">
                    <div class="accordion-body">
                        <div class="row g-3 mb-3">
                            <div class="col-md-4">
                                <label class="form-label">Gewicht envelop+brander+mand+flessen (kg)</label>
                                <input type="number" step="0.1" class="form-control" @bind="fp.EnvelopeWeightKg" />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">Max Altitude (ft)</label>
                                <input type="number" class="form-control" @bind="fp.MaxAltitudeFt" />
                            </div>
                            <div class="col-md-2">
                                <label class="form-label">Lift units</label>
                                <input type="number" step="1" class="form-control" @bind="fp.LiftUnits" />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">Totaal lift (kg)</label>
                                <input type="number" step="0.1" class="form-control" @bind="fp.TotaalLiftKg" />
                            </div>
                        </div>

                        <h6>Gewichten</h6>
                        <table class="table table-sm table-bordered">
                            <thead class="table-secondary">
                                <tr>
                                    <th>Naam</th>
                                    <th style="width:150px">Gewicht (kg)</th>
                                    <th style="width:60px"></th>
                                </tr>
                            </thead>
                            <tbody>
                                <!-- Pilot row (read-only) -->
                                <tr class="table-light">
                                    <td>
                                        <em>Piloot: @(currentPilot?.Name ?? "–")</em>
                                    </td>
                                    <td>@(currentPilot?.WeightKg?.ToString("F1") ?? "–")</td>
                                    <td></td>
                                </tr>
                                @for (int i = 0; i < fp.Passengers.Count; i++)
                                {
                                    var idx = i;
                                    <tr>
                                        <td>
                                            <input type="text" class="form-control form-control-sm"
                                                placeholder="Naam passagier"
                                                value="@fp.Passengers[idx].Name"
                                                @onchange="e => fp.Passengers[idx].Name = e.Value?.ToString() ?? string.Empty" />
                                        </td>
                                        <td>
                                            <input type="number" step="0.1" class="form-control form-control-sm"
                                                value="@fp.Passengers[idx].WeightKg"
                                                @onchange="e => { if (double.TryParse(e.Value?.ToString(), out var w)) fp.Passengers[idx].WeightKg = w; }" />
                                        </td>
                                        <td>
                                            <button class="btn btn-sm btn-outline-danger" @onclick="() => RemovePassenger(idx)">✕</button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot>
                                <tr>
                                    <td colspan="3">
                                        <button class="btn btn-sm btn-outline-success" @onclick="AddPassenger">➕ Passagier toevoegen</button>
                                    </td>
                                </tr>
                                <tr class="table-secondary fw-bold">
                                    <td>Totaal gewicht</td>
                                    <td>@(CalcTotalWeight().ToString("F1")) kg</td>
                                    <td></td>
                                </tr>
                            </tfoot>
                        </table>

                        <div class="mt-2">
                            @if (fp.TotaalLiftKg.HasValue)
                            {
                                @if (fp.TotaalLiftKg.Value > CalcTotalWeight())
                                {
                                    <span class="badge bg-success fs-6">✅ Lift voldoende (@fp.TotaalLiftKg kg &gt; @CalcTotalWeight().ToString("F1") kg)</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger fs-6">❌ Lift onvoldoende (@fp.TotaalLiftKg kg ≤ @CalcTotalWeight().ToString("F1") kg)</span>
                                }
                            }
                        </div>

                        <div class="mt-3">
                            <label class="form-label">Notities</label>
                            <textarea class="form-control" rows="3" @bind="fp.LoadNotes"></textarea>
                        </div>
                    </div>
                </div>
            </div>

            <!-- SECTION 8: Traject -->
            <div class="accordion-item">
                <h2 class="accordion-header">
                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#sec8">
                        8. Traject
                    </button>
                </h2>
                <div id="sec8" class="accordion-collapse collapse">
                    <div class="accordion-body">
                        <div class="mb-3">
                            <label class="form-label">Trajectnotities / waypoints</label>
                            <textarea class="form-control" rows="4" placeholder="Trajectnotities / waypoints..."
                                @bind="fp.Traject"></textarea>
                        </div>

                        <!-- Image upload – Traject -->
                        <div>
                            <label class="form-label fw-semibold">📷 Foto's (trajectkaart, wind chart, ...)</label>
                            <InputFile OnChange="UploadTrajectImages" multiple accept="image/*"
                                class="form-control" />
                            @if (trajectImages.Count > 0)
                            {
                                <div class="d-flex flex-wrap gap-2 mt-2">
                                    @foreach (var img in trajectImages)
                                    {
                                        <div class="position-relative" style="width:140px">
                                            <img src="data:@img.ContentType;base64,@Convert.ToBase64String(img.Data)"
                                                class="img-thumbnail" style="width:140px;height:105px;object-fit:cover" />
                                            <span class="position-absolute top-0 end-0 p-1 text-truncate w-100 small text-muted"
                                                style="font-size:.65rem;background:rgba(255,255,255,.8)">@img.FileName</span>
                                            <button type="button" class="btn btn-danger btn-sm position-absolute top-0 start-0"
                                                style="padding:1px 5px;font-size:.7rem"
                                                @onclick="() => RemoveImage(img)">✕</button>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <!-- SECTION 9: Ballonbulletin -->
            <div class="accordion-item">
                <h2 class="accordion-header">
                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#sec9">
                        9. Ballonbulletin
                    </button>
                </h2>
                <div id="sec9" class="accordion-collapse collapse">
                    <div class="accordion-body">
                        <textarea class="form-control font-monospace" rows="15"
                            placeholder="Plak hier de Skeyes ballonbulletin tekst..."
                            @bind="fp.Ballonbulletin"></textarea>
                    </div>
                </div>
            </div>

        </div><!-- end accordion -->

        <!-- Action buttons -->
        <div class="d-flex gap-2 mt-4 mb-5">
            <button class="btn btn-primary btn-lg" @onclick="SaveFlight" disabled="@saving">
                @if (saving)
                {
                    <span class="spinner-border spinner-border-sm me-1"></span>
                }
                💾 Opslaan
            </button>
            <button class="btn btn-success btn-lg" @onclick="SaveAndPdf" disabled="@saving">
                @if (saving)
                {
                    <span class="spinner-border spinner-border-sm me-1"></span>
                }
                📄 Opslaan &amp; PDF
            </button>
            <a href="/flights" class="btn btn-outline-secondary btn-lg">Annuleren</a>
        </div>

        @if (saveMessage != null)
        {
            <div class="alert @(saveError ? "alert-danger" : "alert-success") alert-dismissible">
                @saveMessage
                <button type="button" class="btn-close" @onclick="() => saveMessage = null"></button>
            </div>
        }
    }
</div>

@code {
    [Parameter] public int? Id { get; set; }

    private FlightPreparation? fp;
    private List<Balloon> balloons = new();
    private List<Pilot> pilots = new();
    private List<Location> locations = new();
    private Pilot? currentPilot;

    // Images kept in memory; persisted on save
    private List<FlightImage> meteoImages = new();
    private List<FlightImage> trajectImages = new();

    private bool fetchingWeather;
    private string? weatherError;
    private bool weatherSuccess;
    private bool saving;
    private string? saveMessage;
    private bool saveError;

    private static readonly string DefaultPaxBriefing =
        "<h2>Pax Briefing</h2>" +
        "<h3>Voor de vlucht – Inflation</h3><ul>" +
        "<li>Wat er staat te gebeuren tijdens inflation</li>" +
        "<li><strong>NIET ROKEN</strong></li>" +
        "<li>Oppassen voor de ventilator</li>" +
        "<li>Alle PAX's en familie wachten achter de snuit van de wagen</li>" +
        "<li>Wanneer de ballon recht staat roept de piloot om in te stappen (toon instapgat)</li>" +
        "<li>Veiligheid checks vermelden (parachute)</li></ul>" +
        "<h3>Tijdens de vaart</h3><ul>" +
        "<li>Enkel vasthouden aan de stokken / mand / lussen / frame gascilinders</li>" +
        "<li>Niets overboord gooien (afval, etc.)</li>" +
        "<li>Uitkijken voor hoogspanning en dieren (paarden/koeien) – melden aan piloot</li></ul>" +
        "<h3>Landingspositie oefenen (na ±30 min)</h3><ul>" +
        "<li>Met de <strong>rug in de vaarrichting</strong></li>" +
        "<li>Stevig vasthouden aan de lussen in de mand</li>" +
        "<li>Licht door de knieën buigen (schok opvangen, kruisbanden deblokkeren)</li>" +
        "<li><strong>Nooit handen uit de mand</strong> als we aan het slepen zijn</li></ul>" +
        "<h3>Voor de landing</h3><ul>" +
        "<li>Alles opbergen (GSM / camera / etc.)</li>" +
        "<li>Landingspositie aannemen</li>" +
        "<li>Pas uitstappen wanneer de piloot het zegt</li></ul>" +
        "<h3>Na de landing</h3><ul>" +
        "<li>Ballon opruimen</li>" +
        "<li>Iets drinken 🙂</li></ul>" +
        "<h3>Algemeen</h3><ul>" +
        "<li>Aangeraden: stevige platte schoenen</li>" +
        "<li>Vraag naar medische conditie waarvan de piloot op de hoogte moet zijn</li></ul>";

    private bool quillReady;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && fp != null && !quillReady)
        {
            quillReady = true;
            await JS.InvokeVoidAsync("quillInit", "pax-briefing-editor", fp.PaxBriefing ?? "");
        }
    }

    // Re-initialize when user opens section 6 (accordion may have been closed on first render)
    private async Task InitQuillOnOpen()
    {
        if (fp == null) return;
        await Task.Delay(50); // let Bootstrap finish the expand animation
        await JS.InvokeVoidAsync("quillInit", "pax-briefing-editor", fp.PaxBriefing ?? "");
    }

    private async Task ReadQuillContent()
    {
        try { fp!.PaxBriefing = await JS.InvokeAsync<string>("quillGetHtml", "pax-briefing-editor"); }
        catch { /* JS not available */ }
    }

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        balloons = await db.Balloons.OrderBy(b => b.Registration).ToListAsync();
        pilots = await db.Pilots.OrderBy(p => p.Name).ToListAsync();
        locations = await db.Locations.OrderBy(l => l.Name).ToListAsync();

        if (Id.HasValue)
        {
            fp = await db.FlightPreparations
                .Include(f => f.Balloon)
                .Include(f => f.Pilot)
                .Include(f => f.Location)
                .Include(f => f.Passengers.OrderBy(p => p.Order))
                .Include(f => f.Images.OrderBy(i => i.Order))
                .FirstOrDefaultAsync(f => f.Id == Id.Value);

            if (fp == null) { Nav.NavigateTo("/flights"); return; }

            currentPilot = fp.Pilot;
            meteoImages   = fp.Images.Where(i => i.Section == "Meteo").ToList();
            trajectImages = fp.Images.Where(i => i.Section == "Traject").ToList();
        }
        else
        {
            fp = new FlightPreparation { PaxBriefing = DefaultPaxBriefing };
        }
    }

    private void OnBalloonChanged()
    {
        if (fp == null) return;
        var balloon = balloons.FirstOrDefault(b => b.Id == fp.BalloonId);
        if (balloon != null && fp.EnvelopeWeightKg == null)
            fp.EnvelopeWeightKg = balloon.EmptyWeightKg;
    }

    private void OnPilotChanged()
    {
        if (fp == null) return;
        currentPilot = pilots.FirstOrDefault(p => p.Id == fp.PilotId);
    }

    private void OnLocationChanged()
    {
        if (fp == null) return;
        var loc = locations.FirstOrDefault(l => l.Id == fp.LocationId);
        if (loc?.AirspaceNotes != null && string.IsNullOrWhiteSpace(fp.Luchtruimstructuur))
            fp.Luchtruimstructuur = loc.AirspaceNotes;
    }

    private async Task FetchWeather()
    {
        if (fp == null) return;
        weatherError = null; weatherSuccess = false;
        var loc = locations.FirstOrDefault(l => l.Id == fp.LocationId);
        if (loc?.IcaoCode == null) { weatherError = "Geen ICAO-code voor deze locatie."; return; }
        fetchingWeather = true;
        try
        {
            var (metar, taf) = await WeatherSvc.FetchAsync(loc.IcaoCode);
            fp.Metar = metar ?? "Geen METAR beschikbaar";
            fp.Taf = taf ?? "Geen TAF beschikbaar";
            weatherSuccess = true;
        }
        catch (Exception ex) { weatherError = $"Fout: {ex.Message}"; }
        finally { fetchingWeather = false; }
    }

    // ── Image upload ─────────────────────────────────────────────────────────
    private const long MaxImageBytes = 15 * 1024 * 1024; // 15 MB per image

    private async Task UploadMeteoImages(InputFileChangeEventArgs e)   => await UploadImages(e, "Meteo");
    private async Task UploadTrajectImages(InputFileChangeEventArgs e) => await UploadImages(e, "Traject");

    private async Task UploadImages(InputFileChangeEventArgs e, string section)
    {
        var targetList = section == "Meteo" ? meteoImages : trajectImages;
        foreach (var file in e.GetMultipleFiles(20))
        {
            if (file.Size > MaxImageBytes) continue;
            using var ms = new System.IO.MemoryStream();
            await file.OpenReadStream(MaxImageBytes).CopyToAsync(ms);
            targetList.Add(new FlightImage
            {
                Section     = section,
                FileName    = file.Name,
                ContentType = file.ContentType,
                Data        = ms.ToArray(),
                Order       = targetList.Count
            });
        }
    }

    private void RemoveImage(FlightImage img)
    {
        meteoImages.Remove(img);
        trajectImages.Remove(img);
    }

    // ── Passengers ───────────────────────────────────────────────────────────
    private void AddPassenger() =>
        fp!.Passengers.Add(new Passenger { Order = fp.Passengers.Count });

    private void RemovePassenger(int index)
    {
        if (index >= 0 && index < fp!.Passengers.Count) fp.Passengers.RemoveAt(index);
    }

    private double CalcTotalWeight() =>
        (fp?.EnvelopeWeightKg ?? 0)
        + (currentPilot?.WeightKg ?? pilots.FirstOrDefault(p => p.Id == fp?.PilotId)?.WeightKg ?? 0)
        + (fp?.Passengers.Sum(p => p.WeightKg) ?? 0);

    // ── Save ─────────────────────────────────────────────────────────────────
    private async Task<FlightPreparation?> SaveInternal()
    {
        if (fp == null) return null;
        await ReadQuillContent(); // pull latest HTML from editor
        saving = true; saveMessage = null;
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            currentPilot = pilots.FirstOrDefault(p => p.Id == fp.PilotId);

            if (fp.Id == 0)
            {
                fp.CreatedAt = fp.UpdatedAt = DateTime.UtcNow;
                var balloon   = fp.Balloon;   fp.Balloon   = null;
                var pilot     = fp.Pilot;     fp.Pilot     = null;
                var location  = fp.Location;  fp.Location  = null;
                var passengers = fp.Passengers.ToList(); fp.Passengers.Clear();

                db.FlightPreparations.Add(fp);
                await db.SaveChangesAsync();

                // Passengers
                for (int i = 0; i < passengers.Count; i++)
                { passengers[i].FlightPreparationId = fp.Id; passengers[i].Order = i; passengers[i].Id = 0; }
                db.Passengers.AddRange(passengers);

                // Images
                var allImages = meteoImages.Concat(trajectImages).ToList();
                for (int i = 0; i < allImages.Count; i++)
                { allImages[i].FlightPreparationId = fp.Id; allImages[i].Id = 0; allImages[i].Order = i; }
                db.FlightImages.AddRange(allImages);

                await db.SaveChangesAsync();
                fp.Balloon = balloon; fp.Pilot = pilot; fp.Location = location;
                fp.Passengers.AddRange(passengers);
            }
            else
            {
                fp.UpdatedAt = DateTime.UtcNow;

                // Replace passengers
                db.Passengers.RemoveRange(await db.Passengers.Where(p => p.FlightPreparationId == fp.Id).ToListAsync());
                var newPax = fp.Passengers.ToList(); fp.Passengers.Clear();
                var balloon  = fp.Balloon;  fp.Balloon  = null;
                var pilot    = fp.Pilot;    fp.Pilot    = null;
                var location = fp.Location; fp.Location = null;
                var images   = fp.Images;   fp.Images   = new();

                db.FlightPreparations.Update(fp);
                await db.SaveChangesAsync();

                // Replace images
                db.FlightImages.RemoveRange(await db.FlightImages.Where(i => i.FlightPreparationId == fp.Id).ToListAsync());
                var allImages = meteoImages.Concat(trajectImages).ToList();
                for (int i = 0; i < allImages.Count; i++)
                { allImages[i].FlightPreparationId = fp.Id; allImages[i].Id = 0; allImages[i].Order = i; }
                db.FlightImages.AddRange(allImages);

                for (int i = 0; i < newPax.Count; i++)
                { newPax[i].FlightPreparationId = fp.Id; newPax[i].Order = i; newPax[i].Id = 0; }
                db.Passengers.AddRange(newPax);
                await db.SaveChangesAsync();

                fp.Balloon = balloon; fp.Pilot = pilot; fp.Location = location;
                fp.Passengers.AddRange(newPax);
            }

            fp.Balloon  = balloons.FirstOrDefault(b => b.Id == fp.BalloonId);
            fp.Pilot    = pilots.FirstOrDefault(p => p.Id == fp.PilotId);
            fp.Location = locations.FirstOrDefault(l => l.Id == fp.LocationId);
            fp.Images   = meteoImages.Concat(trajectImages).ToList();

            saveMessage = "✅ Vaart opgeslagen!"; saveError = false;
            return fp;
        }
        catch (Exception ex) { saveMessage = $"❌ Fout bij opslaan: {ex.Message}"; saveError = true; return null; }
        finally { saving = false; }
    }

    private async Task SaveFlight()
    {
        var saved = await SaveInternal();
        if (saved != null && Id == null)
        {
            Id = saved.Id;
            Nav.NavigateTo($"/flights/{saved.Id}/edit", replace: true);
        }
    }

    private async Task SaveAndPdf()
    {
        var saved = await SaveInternal();
        if (saved == null) return;
        try
        {
            var pdfBytes = PdfSvc.Generate(saved);
            await JS.InvokeVoidAsync("downloadFileFromBytes",
                $"vaartvoorbereiding_{saved.Datum:yyyy-MM-dd}_{saved.Id}.pdf",
                "application/pdf", Convert.ToBase64String(pdfBytes));
        }
        catch (Exception ex) { saveMessage = $"❌ PDF fout: {ex.Message}"; saveError = true; }
    }
}

