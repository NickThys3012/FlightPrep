@page "/flights/new"
@page "/flights/{Id:int}/edit"
@rendermode InteractiveServer
@inject IFlightPreparationService FpSvc
@inject NavigationManager Nav
@inject IPdfService PdfSvc
@inject ISunriseService SunriseSvc
@inject IJSRuntime JS
@inject ITrajectoryService TrajectorySvc
@inject ILogger<FlightEdit> Logger
@inject IEnhancedTrajectoryService EnhancedTrajectorySvc
@inject IGoNoGoService GoNoGoSvc
@using Microsoft.AspNetCore.Components.Forms
@using FlightPrep.Models.Trajectory

<PageTitle>@(Id.HasValue ? "Vaart Bewerken" : "Nieuwe Vaart") – FlightPrep</PageTitle>

<div class="container-fluid mt-3">
    <div class="fp-page-header">
        <h2>@(Id.HasValue ? "Vaart Bewerken" : "Nieuwe Vaart")</h2>
        <a href="/flights" class="btn btn-outline-secondary">Terug</a>
    </div>

    @if (fp == null)
    {
        <p><em>Laden...</em></p>
    }
    else
    {
        <!-- Go/No-Go inline badge (hidden when unknown) -->
        var gng = fp != null ? GoNoGoSvc.Compute(fp, _goNoGoSettings) : "unknown";
        if (gng != "unknown")
        {
            <div class="mb-3">
                <FlightGoNoGoBadge GoNoGoResult="@gng" />
                <span class="text-muted ms-2 small">
                    @(gng == "green" ? "Vlucht goedgekeurd" : gng == "yellow" ? "Voorzichtigheid geboden" : "Vlucht niet toegestaan")
                </span>
            </div>
        }

        <div class="accordion" id="flightAccordion">

            <!-- SECTION 1: Algemene Gegevens -->
            <div class="accordion-item">
                <h2 class="accordion-header">
                    <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#sec1">
                        <span class="acc-num">1</span> Algemene Gegevens
                    </button>
                </h2>
                <div id="sec1" class="accordion-collapse collapse show">
                    <div class="accordion-body">
                        <div class="row g-3">
                            <div class="col-md-3">
                                <label class="form-label">Datum</label>
                                <input type="date" class="form-control" value="@fp?.Datum.ToString("yyyy-MM-dd")"
                                    @onchange="e => { fp!.Datum = DateOnly.Parse(e.Value!.ToString()!); UpdateSunriseSunset(); }" />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">Tijdstip (LT)</label>
                                <input type="time" class="form-control" value="@fp?.Tijdstip.ToString("HH:mm")"
                                    @onchange="e => fp!.Tijdstip = TimeOnly.Parse(e.Value!.ToString()!)" />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">Ballon</label>
                                <select class="form-select" @bind="fp!.BalloonId" @bind:after="OnBalloonChanged">
                                    <option value="">– Selecteer ballon –</option>
                                    @foreach (var b in balloons)
                                    {
                                        <option value="@b.Id">@b.Registration – @b.Type (@(b.VolumeM3.HasValue ? $"{b.VolumeM3:F0} m³" : "–"))</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">Piloot / PIC</label>
                                <select class="form-select" @bind="fp.PilotId" @bind:after="OnPilotChanged">
                                    <option value="">– Selecteer piloot –</option>
                                    @foreach (var p in pilots)
                                    {
                                        <option value="@p.Id">@p.Name</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Locatie</label>
                                <select class="form-select" @bind="fp.LocationId" @bind:after="OnLocationChanged">
                                    <option value="">– Selecteer locatie –</option>
                                    @foreach (var l in locations)
                                    {
                                        <option value="@l.Id">@l.Name @(l.IcaoCode != null ? $"({l.IcaoCode})" : "")</option>
                                    }
                                </select>
                            </div>
                        </div>
                        <div class="mt-3">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" @bind="fp.VeldEigenaarGemeld" id="chkVeldEigenaar" />
                                <label class="form-check-label" for="chkVeldEigenaar">
                                    Veld eigenaar gemeld (indien van toepassing) –
                                    <a href="https://forms.monday.com/forms/90b13ba3fa8356c3f9a6d5f46b10421a?r=euc1" target="_blank" rel="noopener">
                                        formulier invullen
                                    </a>
                                </label>
                            </div>
                        </div>
                        @if (sunriseSunset.HasValue)
                        {
                            <div class="col-12 mt-3">
                                <div class="fp-sun-card">
                                    <span>🌅 Zonsopgang: <strong>@sunriseSunset.Value.Sunrise.ToString("HH:mm") UTC</strong></span>
                                    <span>🌇 Zonsondergang: <strong>@sunriseSunset.Value.Sunset.ToString("HH:mm") UTC</strong></span>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- SECTION 2: Meteorologische Informatie -->
            <div class="accordion-item">
                <h2 class="accordion-header">
                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#sec2">
                        <span class="acc-num">2</span> Meteorologische Informatie
                    </button>
                </h2>
                <div id="sec2" class="accordion-collapse collapse">
                    <div class="accordion-body">
                        <FlightMeteoSection Fp="fp"
                                            CurrentLocation="currentLocation"
                                            MeteoImages="meteoImages" />
                    </div>
                </div>
            </div>

            <!-- SECTION 3: Luchtruim en NOTAMs -->
            <div class="accordion-item">
                <h2 class="accordion-header">
                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#sec3">
                        <span class="acc-num">3</span> Luchtruim en NOTAMs
                    </button>
                </h2>
                <div id="sec3" class="accordion-collapse collapse">
                    <div class="accordion-body">
                        <div class="row g-3">
                            <div class="col-md-3">
                                <label class="form-label">NOTAMs gecontroleerd</label>
                                <select class="form-select" @bind="fp.NotamsGecontroleerd">
                                    <option value="JA">JA</option>
                                    <option value="NEE">NEE</option>
                                </select>
                            </div>
                            <div class="col-12">
                                <label class="form-label">Luchtruimstructuur</label>
                                <textarea class="form-control" rows="3" @bind="fp.Luchtruimstructuur"></textarea>
                            </div>
                            <div class="col-12">
                                <label class="form-label">Beperkingen / gesloten zones</label>
                                <textarea class="form-control" rows="3" @bind="fp.Beperkingen"></textarea>
                            </div>
                            <div class="col-12">
                                <label class="form-label">Obstakels</label>
                                <textarea class="form-control" rows="2" @bind="fp.Obstakels"></textarea>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- SECTION 4: Veiligheid en Communicatie -->
            <div class="accordion-item">
                <h2 class="accordion-header">
                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#sec4">
                        <span class="acc-num">4</span> Veiligheid en Communicatie
                    </button>
                </h2>
                <div id="sec4" class="accordion-collapse collapse">
                    <div class="accordion-body">
                        <div class="row g-3">
                            <div class="col-md-4">
                                <label class="form-label">EHBO-kit en vuurblusser</label>
                                <select class="form-select" @bind="fp.EhboEnBlusser">
                                    <option value="JA">JA</option>
                                    <option value="NEE">NEE</option>
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Passagierslijst ingevuld</label>
                                <select class="form-select" @bind="fp.PassagierslijstIngevuld">
                                    <option value="JA">JA</option>
                                    <option value="NEE">NEE</option>
                                    <option value="NVT">NVT</option>
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Vluchtplan ingediend</label>
                                <select class="form-select" @bind="fp.VluchtplanIngediend">
                                    <option value="JA">JA</option>
                                    <option value="NEE">NEE</option>
                                    <option value="NVT">NVT</option>
                                </select>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- SECTION 5: Technische Controle -->
            <div class="accordion-item">
                <h2 class="accordion-header">
                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#sec5">
                        <span class="acc-num">5</span> Technische Controle
                    </button>
                </h2>
                <div id="sec5" class="accordion-collapse collapse">
                    <div class="accordion-body">
                        <div class="form-check mb-2">
                            <input class="form-check-input" type="checkbox" @bind="fp.BranderGetest" id="chk1" />
                            <label class="form-check-label" for="chk1">Brander getest</label>
                        </div>
                        <div class="form-check mb-2">
                            <input class="form-check-input" type="checkbox" @bind="fp.GasflaconsGecontroleerd" id="chk2" />
                            <label class="form-check-label" for="chk2">Gasflessen gevuld &amp; gecontroleerd</label>
                        </div>
                        <div class="form-check mb-2">
                            <input class="form-check-input" type="checkbox" @bind="fp.BallonVisueel" id="chk3" />
                            <label class="form-check-label" for="chk3">Ballon en mand visueel geïnspecteerd</label>
                        </div>
                        <div class="form-check mb-2">
                            <input class="form-check-input" type="checkbox" @bind="fp.VerankeringenGecontroleerd" id="chk4" />
                            <label class="form-check-label" for="chk4">Verankeringen en touwen gecontroleerd</label>
                        </div>
                        <div class="form-check mb-2">
                            <input class="form-check-input" type="checkbox" @bind="fp.InstrumentenWerkend" id="chk5" />
                            <label class="form-check-label" for="chk5">Instrumenten werkend</label>
                        </div>
                    </div>
                </div>
            </div>

            <!-- SECTION 6: Pax Briefing -->
            <div class="accordion-item">
                <h2 class="accordion-header">
                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse"
                        data-bs-target="#sec6" @onclick="InitQuillOnOpen">
                        <span class="acc-num">6</span> Pax Briefing
                    </button>
                </h2>
                <div id="sec6" class="accordion-collapse collapse">
                    <div class="accordion-body">
                        <div id="pax-briefing-editor" style="min-height:300px"></div>
                    </div>
                </div>
            </div>

            <!-- SECTION 7: Load Calculation -->
            <div class="accordion-item">
                <h2 class="accordion-header">
                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#sec7">
                        <span class="acc-num">7</span> Load Berekening
                    </button>
                </h2>
                <div id="sec7" class="accordion-collapse collapse">
                    <div class="accordion-body">
                        <FlightPassengerList Fp="fp" CurrentPilot="currentPilot" />
                    </div>
                </div>
            </div>

            <!-- SECTION 8: Traject -->
            <div class="accordion-item">
                <h2 class="accordion-header">
                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#sec8">
                        <span class="acc-num">8</span> Traject
                    </button>
                </h2>
                <div id="sec8" class="accordion-collapse collapse">
                    <div class="accordion-body">
                        <div class="mb-3">
                            <label class="form-label">Trajectsimulatie</label>
                            <div class="d-flex align-items-center gap-2 mb-2">
                                <div>
                                    <label class="form-label mb-0 small">Simulatieduur (min)</label>
                                    <input type="number" class="form-control form-control-sm"
                                           style="width:90px"
                                           min="15" max="120" step="5"
                                           @bind="simulationDurationMinutes" />
                                </div>
                                <div class="mt-3">
                                    <button class="btn btn-sm btn-primary" @onclick="SimuleerTraject">
                                        <span class="bi bi-geo-alt"></span> Simuleer trajecten
                                    </button>
                                    <button class="btn btn-sm btn-secondary ms-1"
                                            @onclick="() => showEnhancedPanel = !showEnhancedPanel">
                                        <span class="bi bi-wind"></span> Geavanceerd (3D)
                                    </button>
                                </div>
                            </div>

                            @if (trajectoryError != null)
                            {
                                <div class="alert alert-warning py-1 small">@trajectoryError</div>
                            }

                            @if (simulatedTrajectories != null && simulatedTrajectories.Count > 0)
                            {
                                <div class="mb-2 d-flex flex-wrap gap-2 align-items-center">
                                    @foreach (var t in simulatedTrajectories)
                                    {
                                        <span class="badge" style="background-color:@t.Color">@t.AltitudeFt ft</span>
                                    }
                                    <span class="text-muted small ms-2">@simulatedTrajectories[0].DataSource</span>
                                    @if (fp?.Id > 0)
                                    {
                                        <span class="text-success small ms-auto"><span class="bi bi-check-circle"></span> Automatisch opgeslagen</span>
                                    }
                                    else
                                    {
                                        <span class="text-warning small ms-auto"><span class="bi bi-exclamation-circle"></span> Wordt opgeslagen bij "Opslaan"</span>
                                    }
                                </div>
                                <div id="trajectory-map" style="display:none"></div>
                                <p class="text-muted small mb-0">
                                    ⚠️ Indicatief traject op basis van dead-reckoning. Geen gecertificeerde vliegweg.
                                </p>
                            }
                        </div>

@if (showEnhancedPanel)
{
    <div class="card border-secondary mt-3">
        <div class="card-header py-2">
            <strong>Geavanceerde 3D-simulatie</strong>
            <span class="text-muted small ms-2">(Open-Meteo uurlijkse winddata per druklaag)</span>
        </div>
        <div class="card-body">
            <div class="row g-2 mb-3">
                <div class="col-6 col-md-3">
                    <label class="form-label small mb-1">Klimsnelheid (m/s)</label>
                    <input type="number" class="form-control form-control-sm"
                           min="0.5" max="10" step="0.5"
                           @bind="enhAscentRateMs" />
                </div>
                <div class="col-md-3">
                    <label class="form-label small mb-1">Kruishoogtes (ft) — max. 5</label>
                    @for (int i = 0; i < enhCruiseAltsFt.Count; i++)
                    {
                        var idx = i;
                        <div class="input-group input-group-sm mb-1">
                            <input type="number" class="form-control"
                                   min="500" max="20000" step="500"
                                   value="@enhCruiseAltsFt[idx]"
                                   @onchange="e => enhCruiseAltsFt[idx] = int.TryParse(e.Value?.ToString(), out var v) ? v : enhCruiseAltsFt[idx]" />
                            @if (enhCruiseAltsFt.Count > 1)
                            {
                                <button class="btn btn-outline-danger" @onclick="() => enhCruiseAltsFt.RemoveAt(idx)" type="button">
                                    <span class="bi bi-trash"></span>
                                </button>
                            }
                        </div>
                    }
                    @if (enhCruiseAltsFt.Count < 5)
                    {
                        <div class="d-flex flex-wrap gap-1 mt-1 mb-1">
                            @foreach (var preset in new[] { 500, 1000, 1500, 2000, 3000, 5000 })
                            {
                                var p = preset;
                                @if (!enhCruiseAltsFt.Contains(p))
                                {
                                    <button class="btn btn-outline-secondary btn-sm py-0 px-2"
                                            style="font-size:0.75rem"
                                            @onclick="() => { if (enhCruiseAltsFt.Count < 5) enhCruiseAltsFt.Add(p); }"
                                            type="button">@p</button>
                                }
                            }
                        </div>
                    }
                </div>
                <div class="col-6 col-md-3">
                    <label class="form-label small mb-1">Daalsnelheid (m/s)</label>
                    <input type="number" class="form-control form-control-sm"
                           min="0.5" max="10" step="0.5"
                           @bind="enhDescentRateMs" />
                </div>
                <div class="col-6 col-md-3 d-flex align-items-end">
                    <button class="btn btn-sm btn-primary w-100"
                            @onclick="BerekEnhancedTraject"
                            disabled="@computingEnhanced">
                        @if (computingEnhanced)
                        {
                            <span class="spinner-border spinner-border-sm"></span>
                            <span> Berekenen...</span>
                        }
                        else
                        {
                            <span class="bi bi-calculator"></span>
                            <span> Bereken 3D-traject</span>
                        }
                    </button>
                </div>
            </div>

            @if (enhancedError != null)
            {
                <div class="alert alert-warning py-1 small">@enhancedError</div>
            }

            @if (enhancedTrajectories != null && enhancedTrajectories.Any(t => t.Points.Count > 0))
            {
                <div class="d-flex flex-wrap align-items-center gap-2 mb-2">
                    @foreach (var t in enhancedTrajectories.Where(t => t.Points.Count > 0))
                    {
                        <span class="badge" style="background-color:@t.Color">@t.AltitudeFt ft</span>
                    }
                    <span class="text-muted small">@enhancedTrajectories[0].DataSource · @enhancedTrajectories[0].DurationMinutes min</span>
                    @if (fp?.Id > 0)
                    {
                        <span class="text-success small ms-auto"><span class="bi bi-check-circle"></span> Automatisch opgeslagen</span>
                    }
                    else
                    {
                        <span class="text-warning small ms-auto"><span class="bi bi-exclamation-circle"></span> Wordt opgeslagen bij "Opslaan"</span>
                    }
                </div>
                <div id="enhanced-trajectory-map" style="display:none"></div>
                <p class="text-muted small mb-0">
                    ⚠️ Indicatief traject op basis van Open-Meteo uurlijkse druklaagwind. Geen gecertificeerde vliegweg.
                </p>
            }
        </div>
    </div>
}

                        @{
                            var anyTrajectories =
                                (simulatedTrajectories != null && simulatedTrajectories.Count > 0) ||
                                (enhancedTrajectories  != null && enhancedTrajectories.Any(t => t.Points.Count > 0));
                        }
                        @if (anyTrajectories && fp?.Location?.Latitude != null)
                        {
                            <div class="mt-3">
                                <div class="d-flex flex-wrap gap-1 align-items-center mb-1">
                                    @foreach (var t in (simulatedTrajectories ?? new List<SimulatedTrajectory>()).Concat(enhancedTrajectories?.Where(t => t.Points.Count > 0) ?? new List<SimulatedTrajectory>()))
                                    {
                                        <span class="badge" style="background-color:@t.Color">
                                            @t.AltitudeFt ft @(t.AscentRateMs.HasValue ? "3D" : "DR")
                                        </span>
                                    }
                                    <span class="text-muted small ms-1">
                                        ⚡ Hoogspanning en ✈ luchtruim worden automatisch geladen
                                    </span>
                                </div>
                                <div id="combined-trajectory-map" style="height:450px;border-radius:8px;overflow:hidden;"></div>
                            </div>
                        }

                        <div class="mb-3 mt-3">
                            <label class="form-label">Trajectnotities / waypoints</label>
                            <textarea class="form-control" rows="4" placeholder="Trajectnotities / waypoints..."
                                @bind="fp.Traject"></textarea>
                        </div>

                        <!-- Image upload – Traject -->
                        <div>
                            <FlightImageUpload Label="📷 Foto's (trajectkaart, wind chart, ...)"
                                               Section="Traject"
                                               Images="trajectImages" />
                        </div>
                    </div>
                </div>
            </div>

            <!-- SECTION 9: Ballonbulletin -->
            <div class="accordion-item">
                <h2 class="accordion-header">
                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#sec9">
                        <span class="acc-num">9</span> Ballonbulletin
                    </button>
                </h2>
                <div id="sec9" class="accordion-collapse collapse">
                    <div class="accordion-body">
                        <textarea class="form-control font-monospace" rows="15"
                            placeholder="Plak hier de Skeyes ballonbulletin tekst..."
                            @bind="fp.Ballonbulletin"></textarea>
                    </div>
                </div>
            </div>

        </div><!-- end accordion -->

        <!-- Action buttons -->
        <div class="d-flex gap-2 mt-4 mb-5">
            <button class="btn btn-primary btn-lg" @onclick="SaveFlight" disabled="@saving">
                @if (saving)
                {
                    <span class="spinner-border spinner-border-sm me-1"></span>
                }
                💾 Opslaan
            </button>
            <button class="btn btn-success btn-lg" @onclick="SaveAndPdf" disabled="@saving">
                @if (saving)
                {
                    <span class="spinner-border spinner-border-sm me-1"></span>
                }
                Opslaan & PDF
            </button>
            <a href="/flights" class="btn btn-outline-secondary btn-lg">Annuleren</a>
        </div>

        @if (saveMessage != null)
        {
            <div class="alert @(saveError ? "alert-danger" : "alert-success") alert-dismissible">
                @saveMessage
                <button type="button" class="btn-close" @onclick="() => saveMessage = null"></button>
            </div>
        }
    }
</div>

@code {
    [Parameter] public int? Id { get; set; }

    private FlightPreparation? fp;
    private List<Balloon> balloons = new();
    private List<Pilot> pilots = new();
    private List<Location> locations = new();
    private Pilot? currentPilot;
    private Location? currentLocation;
    private GoNoGoSettings _goNoGoSettings = new();

    // Images kept in memory; persisted on save
    private List<FlightImage> meteoImages = new();
    private List<FlightImage> trajectImages = new();

    private bool saving;
    private string? saveMessage;
    private bool saveError;

    private int simulationDurationMinutes = 60;
    private List<SimulatedTrajectory>? simulatedTrajectories;
    private string? trajectoryError;

    private double enhAscentRateMs   = 3.0;
    private List<int> enhCruiseAltsFt = new() { 3000 };
    private double enhDescentRateMs  = 2.0;
    private List<SimulatedTrajectory>? enhancedTrajectories;
    private bool   showEnhancedPanel  = false;
    private bool   combinedMapRendered = false;
    private string? enhancedError;
    private bool   computingEnhanced  = false;

    private void AddCruiseAlt()
    {
        if (enhCruiseAltsFt.Count < 5)
            enhCruiseAltsFt.Add((enhCruiseAltsFt.Count > 0 ? enhCruiseAltsFt[^1] : 2000) + 1000);
    }

    private (TimeOnly Sunrise, TimeOnly Sunset)? sunriseSunset;

    private static readonly string DefaultPaxBriefing =
        "<h2>Pax Briefing</h2>" +
        "<h3>Voor de vlucht – Inflation</h3><ul>" +
        "<li>Wat er staat te gebeuren tijdens inflation</li>" +
        "<li><strong>NIET ROKEN</strong></li>" +
        "<li>Oppassen voor de ventilator</li>" +
        "<li>Alle PAX's en familie wachten achter de snuit van de wagen</li>" +
        "<li>Wanneer de ballon recht staat roept de piloot om in te stappen (toon instapgat)</li>" +
        "<li>Veiligheid checks vermelden (parachute)</li></ul>" +
        "<h3>Tijdens de vaart</h3><ul>" +
        "<li>Enkel vasthouden aan de stokken / mand / lussen / frame gascilinders</li>" +
        "<li>Niets overboord gooien (afval, etc.)</li>" +
        "<li>Uitkijken voor hoogspanning en dieren (paarden/koeien) – melden aan piloot</li></ul>" +
        "<h3>Landingspositie oefenen (na ±30 min)</h3><ul>" +
        "<li>Met de <strong>rug in de vaarrichting</strong></li>" +
        "<li>Stevig vasthouden aan de lussen in de mand</li>" +
