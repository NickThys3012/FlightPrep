@page "/flights"
@using FlightPrep.Domain.Services
@attribute [Authorize]
@rendermode InteractiveServer
@inject IFlightPreparationService FpSvc
@inject AuthenticationStateProvider AuthStateProvider
@inject IGoNoGoService GoNoGoSvc

<PageTitle>Vaarten – FlightPrep</PageTitle>

<div class="fp-page-header">
    <h2>Vaarten</h2>
    <a href="/flights/new" class="btn btn-primary">✈️ Nieuwe Vaart</a>
</div>

@if (_flights == null)
{
    <p class="text-muted"><em>Laden...</em></p>
}
else if (_totalCount == 0 && _statusFilter == "alle")
{
    <div class="fp-card">
        <div class="fp-empty-state">
            <div class="fp-empty-icon">🎈</div>
            <h5>Geen vaarten gevonden</h5>
            <p>Maak uw eerste vaartvoorbereiding aan.</p>
            <a href="/flights/new" class="btn btn-primary">✈️ Nieuwe Vaart</a>
        </div>
    </div>
}
else
{
    <div class="fp-card p-0 overflow-hidden">
        <!-- Filter bar -->
        <div class="d-flex gap-2 p-3 border-bottom flex-wrap">
            <button class="btn btn-sm @(_statusFilter == "alle" ? "btn-primary" : "btn-outline-secondary")"
                    @onclick='() => SetFilter("alle")'>
                Alle (@_totalAll)
            </button>
            <button class="btn btn-sm @(_statusFilter == "gevlogen" ? "btn-success" : "btn-outline-secondary")"
                    @onclick='() => SetFilter("gevlogen")'>
                ✈️ Gevlogen (@_totalFlown)
            </button>
            <button class="btn btn-sm @(_statusFilter == "niet-gevlogen" ? "btn-warning" : "btn-outline-secondary")"
                    @onclick='() => SetFilter("niet-gevlogen")'>
                📋 Niet gevlogen (@_totalNotFlown)
            </button>
            @if (_totalShared > 0)
            {
                <button class="btn btn-sm @(_statusFilter == "gedeeld" ? "btn-info" : "btn-outline-secondary")"
                        @onclick='() => SetFilter("gedeeld")'>
                    🔗 Gedeeld (@_totalShared)
                </button>
            }
        </div>
        <table class="table mb-0">
            <thead>
            <tr>
                <th style="cursor:pointer" @onclick="ToggleSort">
                    Datum @(_sortDesc ? "▼" : "▲")
                </th>
                <th>Tijdstip</th>
                <th>Ballon</th>
                <th>Piloot</th>
                <th>Locatie</th>
                <th>Status</th>
                <th>Acties</th>
            </tr>
            </thead>
            <tbody>
            @if (!_flights!.Any())
            {
                <tr>
                    <td colspan="7" class="text-center text-muted py-4">Geen vaarten gevonden voor dit filter.</td>
                </tr>
            }
            @foreach (var f in _flights!)
            {
                <tr>
                    <td class="fw-semibold">@f.Date.ToString("dd/MM/yyyy")</td>
                    <td>@f.Time.ToString("HH:mm")</td>
                    <td>@(f.BalloonRegistration ?? "–")</td>
                    <td>@(f.PilotName ?? "–")</td>
                    <td>@(f.LocationName ?? "–")</td>
                    <td>
                        <FlightGoNoGoBadge GoNoGoResult="@GetGoNoGo(f)"/>
                        @if (f.IsFlown)
                        {
                            <span class="badge bg-success ms-1">Gevlogen</span>
                        }
                        @if (f.IsShared)
                        {
                            <span class="badge bg-secondary ms-1">Gedeeld door @f.SharedByName</span>
                        }
                    </td>
                    <td>
                        <div class="btn-group btn-group-sm">
                            <a href="/flights/@f.Id" class="btn btn-outline-primary">Bekijken</a>
                            @if (!f.IsShared)
                            {
                                <a href="/flights/@f.Id/edit" class="btn btn-outline-secondary">Bewerken</a>
                                <button class="btn btn-outline-danger" @onclick="() => ConfirmDelete(f.Id)">Verwijder
                                </button>
                            }
                        </div>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>

    @if (TotalPages > 1)
    {
        <nav class="mt-3 d-flex justify-content-center align-items-center gap-2">
            <button class="btn btn-sm btn-outline-secondary" disabled="@(_currentPage == 1)"
                    @onclick="() => GoToPage(_currentPage - 1)">‹ Vorige</button>
            <span class="text-muted small">Pagina @_currentPage van @TotalPages</span>
            <button class="btn btn-sm btn-outline-secondary" disabled="@(_currentPage == TotalPages)"
                    @onclick="() => GoToPage(_currentPage + 1)">Volgende ›</button>
        </nav>
    }
}

@if (_deleteId.HasValue)
{
    <div class="modal d-block" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Vaart verwijderen?</h5>
                </div>
                <div class="modal-body">
                    <p>Weet u zeker dat u deze vaart wilt verwijderen?</p>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-danger" @onclick="DeleteFlight">Verwijderen</button>
                    <button class="btn btn-secondary" @onclick="() => _deleteId = null">Annuleren</button>
                </div>
            </div>
        </div>
    </div>
    <div class="modal-backdrop fade show"></div>
}