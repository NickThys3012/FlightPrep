@page "/settings/pilots"
@using FlightPrep.Domain.Models
@using FlightPrep.Infrastructure.Data
@attribute [Authorize]
@rendermode InteractiveServer
@inject IDbContextFactory<AppDbContext> DbFactory
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Piloten – FlightPrep</PageTitle>

<div class="container mt-3">
    <h2>👤 Piloten</h2>

    <table class="table table-hover">
        <thead class="table-dark">
        <tr>
            <th>Naam</th>
            <th>Gewicht (kg)</th>
            <th>Acties</th>
        </tr>
        </thead>
        <tbody>
        @foreach (var p in _pilots)
        {
            @if (_editId == p.Id)
            {
                <tr>
                    <td><input class="form-control form-control-sm" @bind="_editPilot.Name"/></td>
                    <td><input type="number" step="0.1" class="form-control form-control-sm"
                               @bind="_editPilot.WeightKg"/></td>
                    <td>
                        <button class="btn btn-sm btn-success" @onclick="SaveEdit">✅ Opslaan</button>
                        <button class="btn btn-sm btn-secondary" @onclick="CancelEdit">Annuleren</button>
                    </td>
                </tr>
            }
            else
            {
                <tr>
                    <td>@p.Name</td>
                    <td>@(p.WeightKg?.ToString("F1") ?? "–")</td>
                    <td>
                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => StartEdit(p)">✏️</button>
                        <button class="btn btn-sm btn-outline-danger" @onclick="() => DeletePilot(p.Id)">🗑️</button>
                    </td>
                </tr>
            }
        }
        @if (_addingNew)
        {
            <tr>
                <td><input class="form-control form-control-sm" @bind="_newPilot.Name" placeholder="Naam"/></td>
                <td><input type="number" step="0.1" class="form-control form-control-sm" @bind="_newPilot.WeightKg"
                           placeholder="Gewicht"/></td>
                <td>
                    <button class="btn btn-sm btn-success" @onclick="SaveNew">✅ Toevoegen</button>
                    <button class="btn btn-sm btn-secondary" @onclick="() => _addingNew = false">Annuleren</button>
                </td>
            </tr>
        }
        </tbody>
    </table>
    @if (!_addingNew)
    {
        <button class="btn btn-primary" @onclick="() => { _addingNew = true; _newPilot = new Pilot(); }">➕ Piloot toevoegen
        </button>
    }
</div>
