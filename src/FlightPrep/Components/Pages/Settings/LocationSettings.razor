@page "/settings/locations"
@using FlightPrep.Domain.Models
@using FlightPrep.Domain.Services
@attribute [Authorize]
@rendermode InteractiveServer
@inject ILocationService LocationSvc
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Locaties – FlightPrep</PageTitle>

<div class="container mt-3">
    <h2>📍 Locaties</h2>

    <table class="table table-hover">
        <thead class="table-dark">
        <tr>
            <th>Naam</th>
            <th>ICAO</th>
            <th>Lat</th>
            <th>Lon</th>
            <th>Hoogte (m)</th>
            <th>Luchtruimnotities</th>
            <th>Acties</th>
        </tr>
        </thead>
        <tbody>
        @foreach (var l in _locations)
        {
            @if (_editId == l.Id)
            {
                <tr>
                    <td><input class="form-control form-control-sm" @bind="_editLoc.Name"/></td>
                    <td><input class="form-control form-control-sm" @bind="_editLoc.IcaoCode" placeholder="EBAW"/></td>
                    <td><input type="number" step="0.000001" class="form-control form-control-sm"
                               @bind="_editLoc.Latitude" placeholder="51.189"/></td>
                    <td><input type="number" step="0.000001" class="form-control form-control-sm"
                               @bind="_editLoc.Longitude" placeholder="4.460"/></td>
                    <td><input type="number" step="1" min="0" class="form-control form-control-sm"
                               @bind="_editLoc.ElevationM" placeholder="0"/></td>
                    <td><textarea class="form-control form-control-sm" rows="2"
                                  @bind="_editLoc.AirspaceNotes"></textarea></td>
                    <td>
                        <button class="btn btn-sm btn-success" @onclick="SaveEdit">✅ Opslaan</button>
                        <button class="btn btn-sm btn-secondary" @onclick="CancelEdit">Annuleren</button>
                    </td>
                </tr>
            }
            else
            {
                <tr>
                    <td>@l.Name</td>
                    <td>@(l.IcaoCode ?? "–")</td>
                    <td>@(l.Latitude.HasValue ? l.Latitude.Value.ToString("F4") : "–")</td>
                    <td>@(l.Longitude.HasValue ? l.Longitude.Value.ToString("F4") : "–")</td>
                    <td>@(l.ElevationM?.ToString("F0") ?? "–") m AMSL</td>
                    <td class="text-truncate" style="max-width:200px">@(l.AirspaceNotes ?? "–")</td>
                    <td>
                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => StartEdit(l)">✏️</button>
                        <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteLocation(l.Id)">🗑️</button>
                    </td>
                </tr>
            }
        }
        @if (_addingNew)
        {
            <tr>
                <td><input class="form-control form-control-sm" @bind="_newLoc.Name" placeholder="Naam"/></td>
                <td><input class="form-control form-control-sm" @bind="_newLoc.IcaoCode" placeholder="EBAW"/></td>
                <td><input type="number" step="0.000001" class="form-control form-control-sm" @bind="_newLoc.Latitude"
                           placeholder="51.189"/></td>
                <td><input type="number" step="0.000001" class="form-control form-control-sm" @bind="_newLoc.Longitude"
                           placeholder="4.460"/></td>
                <td><input type="number" step="1" min="0" class="form-control form-control-sm"
                           @bind="_newLoc.ElevationM" placeholder="0"/></td>
                <td><textarea class="form-control form-control-sm" rows="2" @bind="_newLoc.AirspaceNotes"></textarea>
                </td>
                <td>
                    <button class="btn btn-sm btn-success" @onclick="SaveNew">✅ Toevoegen</button>
                    <button class="btn btn-sm btn-secondary" @onclick="() => _addingNew = false">Annuleren</button>
                </td>
            </tr>
        }
        </tbody>
    </table>
    <p class="text-muted small">💡 Latitude en longitude worden gebruikt voor de zonsopgang/zonsondergang berekening.</p>
    @if (!_addingNew)
    {
        <button class="btn btn-primary" @onclick="() => { _addingNew = true; _newLoc = new Location(); }">➕ Locatie toevoegen
        </button>
    }
</div>
