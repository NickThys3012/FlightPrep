@page "/settings/gonogo"
@rendermode InteractiveServer
@using FlightPrep.Models
@using FlightPrep.Services
@inject GoNoGoService GoNoGoSvc
@inject NavigationManager Nav

<PageTitle>Go/No-Go Instellingen</PageTitle>

<div class="container py-4" style="max-width:640px">
    <h3>⚙️ Go/No-Go Instellingen</h3>
    <p class="text-muted small">
        Stel de drempelwaarden in voor de automatische Go/No-Go indicator. 
        De indicator wordt bepaald op basis van windsnelheid, zichtbaarheid en CAPE.
        De <strong>slechtste</strong> parameter wint.
    </p>

    @if (saved)
    {
        <div class="alert alert-success py-2">✅ Instellingen opgeslagen.</div>
    }

    @if (settings != null)
    {
        <div class="card mb-4">
            <div class="card-header fw-bold">💨 Windsnelheid (kt)</div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-sm-6">
                        <label class="form-label">🟡 Geel vanaf (kt)</label>
                        <input type="number" step="0.5" min="0" class="form-control"
                               @bind="settings.WindYellowKt" />
                        <div class="form-text">Voorzichtig — verhoogd risico</div>
                    </div>
                    <div class="col-sm-6">
                        <label class="form-label">🔴 Rood vanaf (kt)</label>
                        <input type="number" step="0.5" min="0" class="form-control"
                               @bind="settings.WindRedKt" />
                        <div class="form-text">No-Go — te winderig</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="card mb-4">
            <div class="card-header fw-bold">👁️ Zichtbaarheid (km)</div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-sm-6">
                        <label class="form-label">🟡 Geel onder (km)</label>
                        <input type="number" step="0.5" min="0" class="form-control"
                               @bind="settings.VisYellowKm" />
                        <div class="form-text">Voorzichtig</div>
                    </div>
                    <div class="col-sm-6">
                        <label class="form-label">🔴 Rood onder (km)</label>
                        <input type="number" step="0.5" min="0" class="form-control"
                               @bind="settings.VisRedKm" />
                        <div class="form-text">No-Go — te weinig zicht</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="card mb-4">
            <div class="card-header fw-bold">⛈️ CAPE (J/kg)</div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-sm-6">
                        <label class="form-label">🟡 Geel vanaf (J/kg)</label>
                        <input type="number" step="10" min="0" class="form-control"
                               @bind="settings.CapeYellowJkg" />
                        <div class="form-text">Verhoogd convectierisico</div>
                    </div>
                    <div class="col-sm-6">
                        <label class="form-label">🔴 Rood vanaf (J/kg)</label>
                        <input type="number" step="10" min="0" class="form-control"
                               @bind="settings.CapeRedJkg" />
                        <div class="form-text">No-Go — onweer risico</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Live preview -->
        <div class="card mb-4 border-secondary">
            <div class="card-header fw-bold text-secondary">Drempelwaarden samenvatting</div>
            <div class="card-body p-0">
                <table class="table table-sm mb-0">
                    <thead class="table-light">
                        <tr><th>Parameter</th><th>🟢 GO</th><th>🟡 Caution</th><th>🔴 No-Go</th></tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>Wind</td>
                            <td>&lt; @settings.WindYellowKt kt</td>
                            <td>@settings.WindYellowKt – @settings.WindRedKt kt</td>
                            <td>≥ @settings.WindRedKt kt</td>
                        </tr>
                        <tr>
                            <td>Zichtbaarheid</td>
                            <td>≥ @settings.VisYellowKm km</td>
                            <td>@settings.VisRedKm – @settings.VisYellowKm km</td>
                            <td>&lt; @settings.VisRedKm km</td>
                        </tr>
                        <tr>
                            <td>CAPE</td>
                            <td>≤ @settings.CapeYellowJkg J/kg</td>
                            <td>@settings.CapeYellowJkg – @settings.CapeRedJkg J/kg</td>
                            <td>&gt; @settings.CapeRedJkg J/kg</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <div class="d-flex gap-2">
            <button class="btn btn-primary" @onclick="Save">💾 Opslaan</button>
            <button class="btn btn-outline-secondary" @onclick="Reset">↩️ Standaardwaarden</button>
        </div>
    }
</div>

@code {
    private GoNoGoSettings? settings;
    private bool saved;

    protected override async Task OnInitializedAsync()
    {
        settings = await GoNoGoSvc.GetSettingsAsync();
    }

    private async Task Save()
    {
        if (settings == null) return;
        await GoNoGoSvc.SaveSettingsAsync(settings);
        saved = true;
        StateHasChanged();
        await Task.Delay(2500);
        saved = false;
    }

    private void Reset()
    {
        settings = new GoNoGoSettings();
        saved = false;
    }
}
